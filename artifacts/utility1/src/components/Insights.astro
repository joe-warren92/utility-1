---
const articles = [
  {
    category: 'Energy Management',
    title: '5 Ways to Reduce Your Commercial Energy Costs This Quarter',
    date: 'March 15, 2026',
    readTime: '5 min read',
    categoryColor: 'bg-blue-50 text-blue-700',
  },
  {
    category: 'Industry Insights',
    title: 'Understanding Your Business Utility Contract: A Plain English Guide',
    date: 'March 10, 2026',
    readTime: '8 min read',
    categoryColor: 'bg-purple-50 text-purple-700',
  },
  {
    category: 'Sustainability',
    title: 'How Smart Waste Management Can Improve Your Bottom Line',
    date: 'March 5, 2026',
    readTime: '6 min read',
    categoryColor: 'bg-green-50 text-green-700',
  },
];
---

<section class="py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14">
      <div>
        <div class="inline-flex items-center gap-2 text-brand-teal text-[13px] font-semibold tracking-widest uppercase mb-4">
          <div class="w-6 h-px bg-brand-teal"></div>
          Insights &amp; Updates
        </div>
        <h2 class="font-heading font-bold text-[2.75rem] lg:text-[3.5rem] text-brand-navy tracking-tight">
          Latest from our team
        </h2>
        <p class="text-brand-gray text-[1.05rem] mt-3 max-w-md">
          Expert insights, industry news, and practical advice for managing your commercial utilities
        </p>
      </div>
      <a href="#insights" class="inline-flex items-center gap-2 text-brand-navy text-[14px] font-semibold hover:text-brand-teal transition-colors self-start lg:self-auto flex-shrink-0">
        View All Articles →
      </a>
    </div>

    <!-- Articles grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {articles.map(({ category, title, date, readTime, categoryColor }) => (
        <article class="group cursor-pointer">
          <!-- Decorative colored top bar -->
          <div class="h-1 rounded-t-lg bg-brand-teal/20 group-hover:bg-brand-teal transition-colors duration-300 mb-6"></div>

          <div class="p-0">
            <span class={`inline-block px-3 py-1 rounded-full text-[11px] font-semibold mb-4 ${categoryColor}`}>
              {category}
            </span>
            <h3 class="font-heading font-bold text-[1.1rem] text-brand-navy leading-snug mb-4 group-hover:text-brand-teal transition-colors">
              {title}
            </h3>
            <div class="flex items-center gap-3 text-brand-gray-light text-[12px]">
              <span>{date}</span>
              <span class="w-1 h-1 rounded-full bg-brand-gray-light/50"></span>
              <span>{readTime}</span>
            </div>
          </div>

          <div class="mt-5 pt-5 border-t border-gray-100 flex items-center justify-between">
            <span class="text-brand-teal text-[13px] font-semibold group-hover:gap-3 flex items-center gap-1.5 transition-all">
              Read article
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="#insights" class="inline-flex items-center gap-2 px-6 py-3 border border-gray-200 text-brand-navy text-[14px] font-medium rounded-[7px] hover:border-brand-teal/30 hover:bg-brand-gray-pale transition-all">
        View All Articles
      </a>
    </div>
  </div>
</section>
