---
const cases = [
  {
    image: 'https://images.unsplash.com/photo-1553413077-190dd305871c?auto=format&fit=crop&w=700&q=75',
    category: 'Logistics',
    badge: '28% reduction',
    title: 'Reducing operational costs by 28% for a national distribution center',
    savings: '£45,000',
  },
  {
    image: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=700&q=75',
    category: 'Facilities Management',
    badge: '15 sites',
    title: 'Streamlining utility management for a multi-site facilities operator',
    savings: '£32,000',
  },
  {
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=700&q=75',
    category: 'Waste Management',
    badge: '35% reduction',
    title: 'Cutting waste costs by 35% for an industrial manufacturer',
    savings: '£18,500',
  },
];
---

<section id="case-studies" class="py-28 bg-brand-gray-pale">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14">
      <div>
        <div class="inline-flex items-center gap-2 text-brand-teal text-[13px] font-semibold tracking-widest uppercase mb-4">
          <div class="w-6 h-px bg-brand-teal"></div>
          Case Studies
        </div>
        <h2 class="font-heading font-bold text-[2.75rem] lg:text-[3.5rem] text-brand-navy tracking-tight text-balance">
          Real results for real businesses
        </h2>
        <p class="text-brand-gray text-[1.05rem] mt-3 max-w-[520px]">
          See how we've helped businesses across the UK transform their utility management and unlock significant savings
        </p>
      </div>
      <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3 border border-brand-navy/20 text-brand-navy text-[14px] font-semibold rounded-[7px] hover:bg-brand-navy hover:text-white transition-all duration-200 self-start lg:self-auto flex-shrink-0">
        View All Case Studies
      </a>
    </div>

    <!-- Cases grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cases.map(({ image, category, badge, title, savings }) => (
        <div class="group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:border-brand-teal/20 hover:shadow-2xl hover:shadow-brand-navy/10 transition-all duration-400 cursor-pointer">
          <!-- Image -->
          <div class="relative h-52 overflow-hidden">
            <img
              src={image}
              alt={title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/60 to-transparent"></div>
            <!-- Badges overlay -->
            <div class="absolute top-4 left-4 flex gap-2 flex-wrap">
              <span class="px-2.5 py-1 bg-white/95 backdrop-blur-sm text-brand-navy text-[11px] font-semibold rounded-full">
                {category}
              </span>
              <span class="px-2.5 py-1 bg-brand-teal text-white text-[11px] font-semibold rounded-full">
                {badge}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-7">
            <h3 class="font-heading font-bold text-[1.1rem] text-brand-navy leading-snug mb-5">{title}</h3>
            <div class="flex items-center justify-between pt-5 border-t border-gray-100">
              <div>
                <div class="text-[11px] text-brand-gray uppercase tracking-wider font-medium mb-1">Annual Savings</div>
                <div class="font-heading font-bold text-[1.75rem] text-brand-teal tracking-tight">{savings}</div>
              </div>
              <div class="w-10 h-10 rounded-full bg-brand-gray-pale group-hover:bg-brand-teal/10 flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-brand-navy group-hover:text-brand-teal transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
