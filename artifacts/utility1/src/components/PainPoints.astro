---
const pains = [
  {
    n: '01',
    h: '"We\'ve been on the same rate for three years and had no idea."',
    b: 'Auto-renewals roll quietly onto out-of-contract rates. Most businesses only find out when someone finally reads the small print.',
  },
  {
    n: '02',
    h: '"Finance is chasing the supplier over a £4,000 discrepancy. Six weeks and counting."',
    b: 'Unexplained line items, estimated reads, and billing errors that take months to resolve — if they get resolved at all.',
  },
  {
    n: '03',
    h: '"We\'ve got seven sites and seven different renewal dates. It\'s a mess."',
    b: 'No consolidated view, no joined-up reporting, no way to benchmark one site against another.',
  },
  {
    n: '04',
    h: '"We moved into a new unit and inherited someone else\'s contract."',
    b: 'Supplier changeovers, deemed rates, and legacy agreements that nobody set up but everyone is now paying for.',
  },
  {
    n: '05',
    h: '"Got hit with a 40% price increase mid-contract. Nobody called us."',
    b: 'Market moves happen. The difference is whether your supplier tells you — or whether you find out on the next invoice.',
  },
  {
    n: '06',
    h: '"Our ops manager spends two days a month just on utility admin."',
    b: 'Comparing quotes, chasing meter reads, managing renewals. None of it is why you hired them.',
  },
];
---

<section class="relative py-24 overflow-hidden bg-brand-navy">

  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-0 w-[700px] h-[700px] bg-brand-teal/5 rounded-full blur-[160px]"></div>
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 80px 80px;"></div>
  </div>

  <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">

    <div class="grid lg:grid-cols-[1fr_1.5fr] gap-16 items-start">

      <!-- Left: sticky header -->
      <div class="lg:sticky lg:top-32">
        <p data-reveal class="eyebrow" style="color: rgba(59,169,165,0.7)">Sound Familiar?</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-white tracking-[-0.035em] leading-[1.0] mb-5" style="font-size: clamp(2.4rem, 4.5vw, 4rem);">
          We hear these<br />every week.
        </h2>
        <p data-reveal data-delay="2" class="text-white/45 text-[14.5px] leading-relaxed max-w-[320px] mb-8">
          After 500+ audits, we know exactly where commercial utility costs go wrong. Here is what business owners and ops managers tell us when they first get in touch.
        </p>

        <div data-reveal data-delay="3" class="p-6 rounded-xl border border-brand-teal/20 bg-brand-teal/6">
          <p class="font-heading font-bold text-white text-[1.05rem] mb-1 tracking-[-0.02em]">We find the overcharges.<br />We fix them.<br />You keep the savings.</p>
          <p class="text-white/40 text-[12.5px] mb-5 mt-2">Most clients recover £8,000–£45,000 in the first audit.</p>
          <a href="#contact" class="btn-primary text-[13px]">Book a free audit</a>
        </div>
      </div>

      <!-- Right: pain points -->
      <div class="space-y-2">
        {pains.map(({ n, h, b }, i) => (
          <div
            data-reveal
            data-delay={String((i % 3) + 1)}
            class="group flex gap-5 p-5 rounded-xl border border-white/6 hover:border-brand-teal/25 hover:bg-white/4 transition-all duration-300 cursor-default"
          >
            <div class="flex-shrink-0 pt-0.5">
              <span class="font-heading font-bold text-[1.8rem] text-white/8 group-hover:text-brand-teal/30 transition-colors duration-300 leading-none tabular-nums">
                {n}
              </span>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-white/80 text-[0.95rem] tracking-[-0.01em] mb-1.5 leading-snug italic">{h}</h3>
              <p class="text-white/38 text-[13px] leading-relaxed">{b}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
