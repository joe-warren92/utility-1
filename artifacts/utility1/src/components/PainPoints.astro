---
const pains = [
  { n: '01', h: 'Multiple providers, multiple headaches', b: 'Navigating different systems, contacts, and contracts across your entire utility portfolio.' },
  { n: '02', h: 'Missed renewals, forced auto-renewals', b: 'Renewal deadlines slip past and you end up on unfavourable out-of-contract rates.' },
  { n: '03', h: 'Prices rise with no warning', b: 'Unexpected increases arrive on your bill long after the industry moved against you.' },
  { n: '04', h: 'Bills full of unexplained charges', b: 'Line items that no one can explain. Hidden costs buried in complex invoices.' },
  { n: '05', h: 'Hours lost chasing and comparing', b: 'Your finance or ops team spends hours on supplier calls instead of strategic work.' },
  { n: '06', h: 'No single view across the business', b: 'Gas, electric, water, and waste all siloed. No consolidated reporting. No control.' },
];
---

<section class="relative py-36 overflow-hidden bg-brand-navy">

  <!-- Deep atmospheric background -->
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-0 w-[700px] h-[700px] bg-brand-teal/6 rounded-full blur-[160px]"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-brand-navy-light/60 rounded-full blur-[100px]"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 80px 80px;"></div>
  </div>

  <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">

    <div class="grid lg:grid-cols-[1fr_1.4fr] gap-20 items-start">

      <!-- Left: sticky editorial header -->
      <div class="lg:sticky lg:top-32">
        <p data-reveal class="eyebrow" style="color: rgba(59,169,165,0.7)">Common Pain Points</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-[clamp(2.6rem,5vw,4.5rem)] text-white tracking-[-0.035em] leading-[1.0] mb-6">
          Sound<br />familiar?
        </h2>
        <p data-reveal data-delay="2" class="text-white/45 text-[15px] leading-relaxed max-w-[340px] mb-10">
          We built Utility 1 because we have seen these frustrations destroy productivity and drain budgets across hundreds of businesses.
        </p>

        <!-- There is a better way CTA card -->
        <div data-reveal data-delay="3" class="p-7 rounded-2xl border border-brand-teal/20 bg-brand-teal/6">
          <p class="font-heading font-bold text-white text-[1.15rem] mb-1 tracking-[-0.02em]">There is a better way.</p>
          <p class="text-white/45 text-[13px] mb-6">One partner. Every utility. Total clarity.</p>
          <div class="flex flex-col gap-3">
            <a href="#how-it-works" class="btn-primary text-[13.5px]">See how we help</a>
            <a href="#contact" class="btn-ghost text-[13.5px]">Talk to an expert →</a>
          </div>
        </div>
      </div>

      <!-- Right: pain points list -->
      <div class="space-y-3">
        {pains.map(({ n, h, b }, i) => (
          <div
            data-reveal
            data-delay={String((i % 3) + 1)}
            class="group flex gap-6 p-6 rounded-xl border border-white/7 hover:border-brand-teal/25 hover:bg-white/4 transition-all duration-300 cursor-default"
          >
            <div class="flex-shrink-0 pt-0.5">
              <span class="font-heading font-bold text-[2rem] text-white/10 group-hover:text-brand-teal/35 transition-colors duration-300 leading-none tabular-nums">
                {n}
              </span>
            </div>
            <div>
              <h3 class="font-heading font-bold text-white/85 text-[1rem] tracking-[-0.02em] mb-1.5">{h}</h3>
              <p class="text-white/40 text-[13.5px] leading-relaxed">{b}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
