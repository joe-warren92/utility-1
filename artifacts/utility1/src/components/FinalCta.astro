---
---

<section id="contact" class="relative overflow-hidden py-28 bg-brand-gray-pale">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1400&q=60"
      alt="Commercial facilities"
      class="w-full h-full object-cover opacity-8"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-brand-gray-pale/95"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: CTA -->
      <div>
        <div class="inline-flex items-center gap-2 text-brand-teal text-[13px] font-semibold tracking-widest uppercase mb-4">
          <div class="w-6 h-px bg-brand-teal"></div>
          Get Started Today
        </div>
        <h2 class="font-heading font-bold text-[2.75rem] lg:text-[3.5rem] text-brand-navy tracking-tight mb-5 text-balance">
          Ready to simplify
          <span class="block text-brand-teal">your utilities?</span>
        </h2>
        <p class="text-brand-gray text-[1.05rem] leading-relaxed mb-10 max-w-md">
          Get a free, no-obligation review of your current setup. We will show you exactly where you could save.
        </p>

        <!-- Contact form (simple) -->
        <form class="space-y-4 max-w-md" onsubmit="return false;">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[13px] font-medium text-brand-navy mb-1.5">First name</label>
              <input
                type="text"
                placeholder="James"
                class="w-full px-4 py-3 rounded-[7px] border border-gray-200 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all"
              />
            </div>
            <div>
              <label class="block text-[13px] font-medium text-brand-navy mb-1.5">Last name</label>
              <input
                type="text"
                placeholder="Thompson"
                class="w-full px-4 py-3 rounded-[7px] border border-gray-200 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all"
              />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-medium text-brand-navy mb-1.5">Business email</label>
            <input
              type="email"
              placeholder="james@company.co.uk"
              class="w-full px-4 py-3 rounded-[7px] border border-gray-200 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all"
            />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-brand-navy mb-1.5">Company name</label>
            <input
              type="text"
              placeholder="Acme Ltd"
              class="w-full px-4 py-3 rounded-[7px] border border-gray-200 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all"
            />
          </div>
          <button
            type="submit"
            class="w-full py-3.5 bg-brand-teal text-white text-[15px] font-semibold rounded-[7px] hover:bg-brand-teal-dark transition-colors shadow-lg shadow-brand-teal/25"
          >
            Get Your Free Review
          </button>
          <p class="text-brand-gray-light text-[12px] text-center">No obligation. No spam. Just clarity.</p>
        </form>
      </div>

      <!-- Right: Contact details + guide download -->
      <div class="space-y-6">
        <!-- Download guide card -->
        <div class="p-8 bg-brand-navy rounded-2xl">
          <div class="w-12 h-12 bg-brand-teal/20 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="font-heading font-bold text-white text-[1.2rem] mb-2">Free Utilities Guide</h3>
          <p class="text-white/60 text-[14px] mb-5">Download our plain-English guide to commercial utility management and start saving today.</p>
          <button class="w-full py-3 border border-white/20 text-white text-[14px] font-medium rounded-xl hover:bg-white/5 transition-colors">
            Download Guide
          </button>
        </div>

        <!-- Contact info -->
        <div class="grid grid-cols-2 gap-4">
          <div class="p-6 bg-white rounded-xl border border-gray-100 hover:border-brand-teal/20 transition-colors">
            <div class="w-9 h-9 bg-brand-teal/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <p class="text-[11px] font-semibold tracking-wider uppercase text-brand-gray mb-1">Call us</p>
            <p class="font-heading font-bold text-brand-navy text-[15px]">0800 123 4567</p>
            <p class="text-brand-gray-light text-[12px] mt-1">Mon–Fri, 8am–6pm</p>
          </div>

          <div class="p-6 bg-white rounded-xl border border-gray-100 hover:border-brand-teal/20 transition-colors">
            <div class="w-9 h-9 bg-brand-teal/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-[11px] font-semibold tracking-wider uppercase text-brand-gray mb-1">Email us</p>
            <p class="font-heading font-bold text-brand-navy text-[14px] break-all">hello@utility1.co.uk</p>
            <p class="text-brand-gray-light text-[12px] mt-1">Response within 24hrs</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
