---
---

<section class="relative py-28 overflow-hidden bg-brand-navy">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1664575600850-c4b712e6e2bf?auto=format&fit=crop&w=1400&q=75"
      alt="Professional warehouse operations manager"
      class="w-full h-full object-cover opacity-20"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-navy via-brand-navy/95 to-brand-navy/80"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <h2 class="font-heading font-bold text-[2.75rem] lg:text-[3.5rem] text-white tracking-tight mb-5 text-balance">
          Built for businesses that value
          <span class="block text-brand-teal">clarity over complexity</span>
        </h2>
        <p class="text-white/60 text-[1.05rem] leading-relaxed mb-10">
          We do not believe in locking you into contracts you do not understand or charging for services you do not need.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-teal text-white text-[15px] font-semibold rounded-[7px] hover:bg-brand-teal-dark transition-all shadow-lg shadow-brand-teal/25">
            Get Your Free Review
          </a>
          <a href="tel:08001234567" class="inline-flex items-center gap-2 px-7 py-3.5 border border-white/20 text-white text-[15px] font-medium rounded-xl hover:border-white/40 hover:bg-white/5 transition-all">
            Call: 0800 123 4567
          </a>
        </div>
      </div>

      <!-- Right: Value props -->
      <div class="grid grid-cols-1 gap-4">
        {[
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            title: 'Transparency',
            description: 'Every cost breakdown, clearly explained',
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`,
            title: 'Flexibility',
            description: 'No lock-ins, no hidden fees, no surprises',
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>`,
            title: 'Support',
            description: 'Real people, not automated responses',
          },
        ].map(({ icon, title, description }) => (
          <div class="flex items-center gap-5 p-5 rounded-xl border border-white/10 bg-white/4 hover:bg-white/8 transition-colors">
            <div class="w-10 h-10 rounded-xl bg-brand-teal/20 flex items-center justify-center text-brand-teal flex-shrink-0" set:html={icon} />
            <div>
              <h3 class="font-heading font-semibold text-white text-[15px]">{title}</h3>
              <p class="text-white/50 text-[13px] mt-0.5">{description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
