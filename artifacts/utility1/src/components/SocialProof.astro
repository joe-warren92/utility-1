---
---

<section class="bg-white border-b border-black/6 py-12 overflow-hidden">
  <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

    <div class="flex flex-col lg:flex-row items-start lg:items-center gap-10 lg:gap-16">

      <!-- Trusted by text -->
      <div class="flex-shrink-0">
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-brand-gray-light mb-0">Trusted by UK businesses</p>
      </div>

      <!-- Partner logos row -->
      <div class="flex items-center gap-10 xl:gap-14 flex-wrap flex-1">
        {[
          { name: 'Tesco', abbr: 'T' },
          { name: 'Sainsbury\'s', abbr: 'S' },
          { name: 'NHS Supply', abbr: 'NHS' },
          { name: 'Prologis', abbr: 'P' },
        ].map(({ name, abbr }) => (
          <div class="flex items-center gap-2.5 opacity-30 hover:opacity-55 transition-opacity duration-300 cursor-default">
            <div class="w-7 h-7 rounded bg-brand-navy/10 flex items-center justify-center">
              <span class="text-brand-navy text-[9px] font-bold">{abbr}</span>
            </div>
            <span class="font-heading font-semibold text-brand-navy text-[13px] tracking-[0.06em] uppercase">{name}</span>
          </div>
        ))}
      </div>

      <!-- Divider -->
      <div class="hidden lg:block w-px h-10 bg-black/8 flex-shrink-0"></div>

      <!-- Mini testimonials -->
      <div class="flex flex-col sm:flex-row gap-4 lg:gap-5 flex-shrink-0">
        {[
          { q: '"32% savings in year one"', role: 'Operations Director' },
          { q: '"Finally — transparent billing"', role: 'Finance Manager' },
        ].map(({ q, role }) => (
          <div class="flex items-start gap-3 max-w-[220px]">
            <div class="w-1 flex-shrink-0 bg-brand-teal rounded-full mt-1" style="height:32px"></div>
            <div>
              <p class="text-brand-navy text-[12.5px] font-medium leading-snug italic">{q}</p>
              <p class="text-brand-gray-light text-[11px] mt-1">{role}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
