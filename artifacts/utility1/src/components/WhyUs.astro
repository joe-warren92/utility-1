---
const points = [
  'No hidden fees or surprise charges',
  'Transparent pricing and contract terms',
  'Dedicated account manager',
  'Proactive renewal management',
];
---

<section class="py-28 bg-brand-gray-pale">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Image -->
      <div class="relative order-2 lg:order-1">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80"
            alt="Commercial warehouse operations"
            class="w-full h-[480px] object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-tr from-brand-navy/40 to-transparent"></div>
        </div>
        <!-- Since 2012 badge -->
        <div class="absolute -bottom-5 -right-5 lg:right-0 bg-brand-teal rounded-2xl p-6 shadow-xl">
          <div class="text-white text-[10px] font-semibold tracking-widest uppercase mb-1 opacity-80">Since 2012</div>
          <div class="font-heading font-bold text-white text-[2.5rem] leading-none">12+</div>
          <div class="text-white/80 text-[13px] mt-1">Years Serving UK Businesses</div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 text-brand-teal text-[13px] font-semibold tracking-widest uppercase mb-4">
          <div class="w-6 h-px bg-brand-teal"></div>
          Why Choose Us
        </div>
        <h2 class="font-heading font-bold text-[2.75rem] lg:text-[3.25rem] text-brand-navy tracking-tight mb-5 text-balance">
          Your partner, not just your supplier
        </h2>
        <p class="text-brand-gray text-[1.05rem] leading-relaxed mb-10">
          We are not here to sell you things you do not need. We are here to make utilities simple, cost-effective, and one less thing to worry about.
        </p>

        <!-- Checkpoints -->
        <ul class="space-y-3.5 mb-10">
          {points.map((point) => (
            <li class="flex items-center gap-3.5">
              <div class="w-6 h-6 rounded-full bg-brand-teal/15 flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20,6 9,17 4,12"/>
                </svg>
              </div>
              <span class="text-brand-navy text-[15px] font-medium">{point}</span>
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-3">
          <a href="#about" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-navy text-white text-[14px] font-semibold rounded-[7px] hover:bg-brand-navy-dark transition-colors shadow-lg shadow-brand-navy/20">
            Learn More About Us
          </a>
          <a href="#case-studies" class="inline-flex items-center gap-2 px-6 py-3 text-brand-navy text-[14px] font-medium hover:text-brand-teal transition-colors">
            View Case Studies →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
