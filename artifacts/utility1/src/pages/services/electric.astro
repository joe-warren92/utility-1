---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Commercial Electricity Contracts | Utility 1 — Cut Your Electricity Costs by Up to 24%"
  description="We audit your commercial electricity contracts, identify hidden charges, and renegotiate on your behalf. Average saving £7,800 per year. Free audit, no obligation."
>
  <Nav />

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="relative flex flex-col overflow-hidden bg-[#06101a]" style="min-height: 80vh;">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?auto=format&fit=crop&w=1800&q=85"
        alt="Commercial electrical infrastructure"
        class="absolute inset-0 w-full h-full object-cover object-center hero-kenburns"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(6,16,26,0.97) 0%, rgba(6,16,26,0.88) 50%, rgba(6,16,26,0.50) 100%);"></div>
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(6,16,26,0.80) 0%, transparent 55%);"></div>
    </div>

    <div class="relative flex flex-col justify-center flex-1" style="padding-top: 130px; padding-bottom: 80px;">
      <div class="max-w-[1360px] mx-auto px-8 xl:px-12 w-full">

        <!-- Breadcrumb -->
        <div data-reveal class="flex items-center gap-2 text-white/35 text-[12px] mb-8">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/#services" class="hover:text-white/60 transition-colors">Services</a>
          <span>/</span>
          <span class="text-brand-teal">Commercial Electric</span>
        </div>

        <div class="max-w-[760px]">
          <p data-reveal class="eyebrow">Commercial Electricity</p>
          <h1 data-reveal data-delay="1" class="font-heading font-bold text-white tracking-[-0.038em] leading-[1.0] mb-5" style="font-size: clamp(2.8rem, 6vw, 6rem);">
            Your electricity bill<br />has more in it<br />than you think.
          </h1>
          <p data-reveal data-delay="2" class="text-white/55 leading-relaxed max-w-[520px] mb-10" style="font-size: 1.1rem;">
            Pass-through charges, reactive power penalties, wrong profile classes, deemed rates — electricity bills are the most complicated utility invoice there is. We read every line, benchmark every charge, and fix what's wrong.
          </p>

          <div data-reveal data-delay="3" class="flex flex-wrap items-center gap-4 mb-12">
            <a href="#contact" class="btn-primary" style="font-size: 15px; padding: 15px 32px;">
              Get a free electricity audit
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:08001234567" class="btn-ghost" style="font-size: 14px; padding: 14px 26px;">
              0800 123 4567
            </a>
          </div>

          <!-- Inline proof stats -->
          <div data-reveal data-delay="4" class="flex flex-wrap gap-8">
            {[
              { v: '24%', l: 'avg. electricity cost reduction' },
              { v: '£7,800', l: 'avg. annual saving' },
              { v: '600+', l: 'electricity audits completed' },
            ].map(({ v, l }) => (
              <div>
                <div class="font-heading font-bold text-white leading-none tracking-[-0.03em]" style="font-size: 1.5rem;">{v}</div>
                <div class="text-white/35 text-[11px] uppercase tracking-[0.1em] mt-1">{l}</div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Problem strip ─────────────────────────────────── -->
  <section class="bg-white border-b border-black/6 py-10">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-10 divide-y-2 lg:divide-y-0 lg:divide-x divide-black/6">
        {[
          { h: '3 in 10', sub: 'businesses are on the wrong electricity meter profile class — paying more than they should by default' },
          { h: '£9,200', sub: 'average annual overspend on electricity before a Utility 1 audit' },
          { h: '18 months', sub: 'average time a new supply sits on a deemed rate before anyone acts on it' },
          { h: '67%', sub: 'of commercial electricity bills contain at least one chargeable billing error' },
        ].map(({ h, sub }) => (
          <div class="pt-4 lg:pt-0 lg:pl-10 first:pl-0 first:pt-0">
            <div class="font-heading font-bold text-brand-teal leading-none tracking-[-0.04em] mb-1.5" style="font-size: 2rem;">{h}</div>
            <p class="text-brand-gray text-[13px] leading-relaxed">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── What we do ────────────────────────────────────── -->
  <section class="py-28 bg-brand-off-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[700px] h-[500px] bg-brand-teal/3 rounded-full blur-[180px] translate-x-1/3 pointer-events-none"></div>
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

      <div class="grid lg:grid-cols-2 gap-20 items-center">

        <div>
          <p data-reveal class="eyebrow">What We Do</p>
          <h2 data-reveal data-delay="1" class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02] mb-5" style="font-size: clamp(2.2rem, 4vw, 3.5rem);">
            We go through your<br />electricity bill<br />line by line.
          </h2>
          <p data-reveal data-delay="2" class="text-brand-gray text-[14.5px] leading-relaxed max-w-[420px] mb-10">
            Most businesses only look at the headline unit rate. We look at everything — because that's where the real overspend hides. No charge, no obligation until we find savings worth pursuing.
          </p>

          <div class="space-y-5">
            {[
              {
                title: 'Full electricity contract audit',
                body: 'We benchmark your unit rate, standing charge, capacity charges, and all pass-through levies against live market rates. Most audits surface 15–30% in addressable overspend within 48 hours.',
              },
              {
                title: 'Half-hourly data analysis',
                body: 'For HH-metered sites, we analyse your consumption profile to identify demand peaks, reactive power charges, and whether your capacity limit is correctly set. Incorrectly set capacity is one of the most common and fixable sources of overcharging.',
              },
              {
                title: 'Supplier tender and negotiation',
                body: 'We take your verified data to our panel of pre-qualified electricity suppliers — including suppliers you won\'t find on comparison sites — and run a genuine competitive tender. You see every offer before anything is signed.',
              },
              {
                title: 'Renewal management and monitoring',
                body: 'We track your contract end dates and alert you six months in advance — every time. No site will ever quietly roll onto a deemed rate again. We also monitor mid-contract for out-of-market pricing.',
              },
            ].map(({ title, body }, i) => (
              <div data-reveal data-delay={String(i + 1)} class="flex gap-4 p-5 rounded-xl border border-black/6 bg-white hover:border-brand-teal/25 transition-colors duration-300">
                <div class="w-5 h-5 rounded-full bg-brand-teal/15 border border-brand-teal/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <p class="font-heading font-semibold text-brand-navy text-[14px] tracking-[-0.02em] mb-1">{title}</p>
                  <p class="text-brand-gray text-[13px] leading-relaxed">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: image + floating cards -->
        <div data-reveal="right" class="relative">
          <div class="relative rounded-2xl overflow-hidden" style="height: 540px;">
            <img
              src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=900&q=80"
              alt="Commercial electrical switchgear"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-br from-brand-navy/30 via-transparent to-brand-navy/20"></div>
          </div>
          <!-- Floating result card -->
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-6 shadow-[0_8px_48px_rgba(15,25,35,0.12)]" style="min-width: 220px;">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-brand-gray-light mb-1">Recent electricity audit</div>
            <div class="font-heading font-bold text-brand-navy leading-none tracking-[-0.04em]" style="font-size: 2.4rem;">£11,400</div>
            <div class="text-brand-gray text-[12px] mt-1">recovered — wrong capacity charge on HH meter</div>
            <div class="text-brand-teal text-[11px] font-semibold mt-2">14 months back-billed</div>
          </div>
          <!-- Top badge -->
          <div class="absolute top-6 -right-4 bg-brand-teal rounded-xl p-4 shadow-[0_8px_32px_rgba(59,169,165,0.35)]">
            <div class="text-white/75 text-[10px] uppercase tracking-wider mb-1">First audit</div>
            <div class="font-heading font-bold text-white leading-none tracking-[-0.03em]" style="font-size: 1.4rem;">Free</div>
            <div class="text-white/60 text-[11px] mt-0.5">No obligation</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Common problems ───────────────────────────────── -->
  <section class="py-24 bg-brand-navy relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 80px 80px;"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[500px] bg-brand-teal/5 rounded-full blur-[150px]"></div>

    <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="max-w-[640px] mb-14">
        <p data-reveal class="eyebrow" style="color: rgba(59,169,165,0.7)">Common Electricity Problems</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-white tracking-[-0.035em] leading-[1.02]" style="font-size: clamp(2.2rem, 4vw, 3.5rem);">
          We hear this every week.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            q: '"We had no idea what reactive power charges even were."',
            a: 'Reactive power penalties are added when your power factor falls below a threshold. They\'re legal, but often fixable with power factor correction — something most suppliers won\'t tell you about.',
          },
          {
            q: '"Our unit rate looks fine but the bill keeps climbing."',
            a: 'Unit rates are only one part of the bill. DUoS, TUoS, and BSuoS are pass-through charges that can be structured better — or that you\'re simply being overcharged on.',
          },
          {
            q: '"We moved into a new site and took the existing electricity supply."',
            a: 'Deemed rates on inherited supplies can be 50–80% above market. Many businesses don\'t realise they\'ve been on one for months. We find these and fix them fast.',
          },
          {
            q: '"The meter profile class doesn\'t match how we actually use electricity."',
            a: 'Being on the wrong profile class means paying distribution charges based on an incorrect pattern. Reclassification can deliver an immediate, permanent cost reduction.',
          },
          {
            q: '"We got a surprise bill for a period we thought was covered."',
            a: 'Electricity billing errors — particularly around estimated reads and supply start/end dates — are extremely common. We identify and dispute these as part of every audit.',
          },
          {
            q: '"Nobody warned us when our electricity contract ended."',
            a: 'Most suppliers aren\'t required to warn you before you roll onto a deemed rate. We are. Every client on our renewal management gets a 6-month advance alert, every time.',
          },
        ].map(({ q, a }, i) => (
          <div
            data-reveal
            data-delay={String((i % 3) + 1)}
            class="group p-6 rounded-xl border border-white/7 hover:border-brand-teal/25 hover:bg-white/4 transition-all duration-300"
          >
            <p class="font-heading font-semibold text-white/80 text-[0.95rem] leading-snug italic mb-3 tracking-[-0.01em]">{q}</p>
            <div class="w-8 h-px bg-brand-teal/30 mb-3 group-hover:w-12 group-hover:bg-brand-teal transition-all duration-300"></div>
            <p class="text-white/40 text-[13px] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Case study ────────────────────────────────────── -->
  <section class="py-28 bg-white relative overflow-hidden">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div data-reveal class="relative rounded-2xl overflow-hidden" style="height: 460px;">
          <img
            src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=900&q=80"
            alt="Retail chain electricity audit"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-brand-navy/20 to-transparent"></div>
          <!-- Savings callout -->
          <div class="absolute bottom-6 left-6 right-6">
            <div class="p-5 rounded-xl bg-brand-navy/90 backdrop-blur-sm border border-white/10">
              <div class="flex items-end justify-between">
                <div>
                  <div class="text-white/45 text-[10px] uppercase tracking-[0.1em] mb-1">Annual electricity saving</div>
                  <div class="font-heading font-bold text-brand-teal leading-none tracking-[-0.04em]" style="font-size: 2.5rem;">£27,400</div>
                </div>
                <div class="text-right">
                  <div class="text-brand-teal font-semibold text-[1.1rem]">24%</div>
                  <div class="text-white/40 text-[11px]">contract reduction</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div data-reveal="right">
          <p class="eyebrow">Electricity Case Study</p>
          <h2 class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02] mb-4" style="font-size: clamp(1.9rem, 3.5vw, 2.8rem);">
            A retail chain was paying the wrong rate on two of its eight sites.
          </h2>
          <div class="space-y-4 text-brand-gray text-[14px] leading-relaxed mb-8">
            <p>A national fashion retailer came to us with eight sites across three electricity contracts with two suppliers. Finance had flagged that bills were higher than expected but couldn't identify where the problem was.</p>
            <p>Our audit found two sites on the wrong meter profile class — they'd been mis-classified at the start of the supply and nobody had corrected it. One site had also been on a deemed rate for eleven months following a store refurbishment, with the new supply never properly contracted.</p>
            <p>We corrected the profile classes, recovered eleven months of back-billing on the deemed rate, and ran a full market tender across all eight sites. New contracts were live within four weeks.</p>
            <p class="italic text-brand-navy/70">"The profile class issue alone was worth more than we expected. Something that had been wrong for years, fixed in a week." — Finance Director</p>
          </div>

          <div class="flex flex-wrap gap-5 pt-6 border-t border-black/6 mb-8">
            {[
              { v: '8', l: 'sites audited' },
              { v: '£27,400', l: 'annual saving' },
              { v: '4 weeks', l: 'to completion' },
            ].map(({ v, l }) => (
              <div>
                <div class="font-heading font-bold text-brand-navy leading-none tracking-[-0.03em]" style="font-size: 1.5rem;">{v}</div>
                <div class="text-brand-gray-light text-[11px] uppercase tracking-[0.1em] mt-1">{l}</div>
              </div>
            ))}
          </div>

          <a href="#contact" class="btn-primary">
            Start your electricity audit
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── How it works ───────────────────────────────────── -->
  <section class="py-24 bg-brand-off-white relative overflow-hidden">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

      <div class="max-w-[640px] mb-16">
        <p data-reveal class="eyebrow">The Process</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02]" style="font-size: clamp(2.2rem, 4vw, 3.5rem);">
          From first contact to<br />savings in four weeks.
        </h2>
      </div>

      <div class="space-y-0 divide-y divide-black/6">
        {[
          { n: '01', title: 'Send us your latest electricity bill', body: 'That\'s all we need to start. No lengthy forms, no long calls. We can usually identify savings within 24 hours of receiving your current contract details and a recent invoice.', time: '24 hours' },
          { n: '02', title: 'We audit and benchmark every charge', body: 'Unit rate, standing charge, capacity, DUoS, TUoS, BSuoS, CCL, reactive power — we check every line against the current market. You get a clear, no-jargon summary of what you\'re overpaying and why.', time: '2–3 days' },
          { n: '03', title: 'We go to market on your behalf', body: 'With your verified consumption data and corrected profile, we run a competitive tender with our pre-qualified supplier panel. We negotiate, not you. You choose from a shortlist of verified offers.', time: '1–2 weeks' },
          { n: '04', title: 'New contract. We handle the admin.', body: 'Paperwork, meter registration, supply start notifications, final billing from the old supplier. We handle all of it. Your team does nothing except approve the new agreement.', time: '1–2 weeks' },
        ].map(({ n, title, body, time }, i) => (
          <div
            data-reveal
            data-delay={String((i % 2) + 1)}
            class="group grid grid-cols-[80px_1fr_auto] items-center gap-6 lg:gap-12 py-8 hover:bg-white transition-colors duration-300 -mx-8 px-8 xl:-mx-12 xl:px-12 rounded-xl"
          >
            <div class="font-heading font-bold text-[2.8rem] text-black/7 group-hover:text-brand-teal/20 transition-colors leading-none tabular-nums tracking-[-0.04em]">{n}</div>
            <div>
              <h3 class="font-heading font-bold text-brand-navy text-[1.1rem] tracking-[-0.025em] mb-1.5 group-hover:text-brand-teal transition-colors duration-300">{title}</h3>
              <p class="text-brand-gray text-[13.5px] leading-relaxed max-w-[520px]">{body}</p>
            </div>
            <div class="hidden lg:flex flex-col items-end">
              <span class="text-[10px] uppercase tracking-[0.12em] text-brand-gray-light mb-1">Timeline</span>
              <span class="font-heading font-semibold text-brand-navy text-[14px]">{time}</span>
              <div class="w-8 h-px bg-brand-teal/40 mt-2 group-hover:w-14 group-hover:bg-brand-teal transition-all duration-300"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-20">

        <div class="lg:sticky lg:top-32 self-start">
          <p data-reveal class="eyebrow">FAQ</p>
          <h2 data-reveal data-delay="1" class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02] mb-5" style="font-size: clamp(2rem, 3.5vw, 3rem);">
            Questions we get asked every day.
          </h2>
          <p data-reveal data-delay="2" class="text-brand-gray text-[14px] leading-relaxed mb-8">
            Straight answers. No sales pitch.
          </p>
          <a href="#contact" class="btn-dark text-[13.5px]">Still have a question? Ask us.</a>
        </div>

        <div class="space-y-0 divide-y divide-black/6" id="faq">
          {[
            { q: 'What is a deemed rate and why does it matter?', a: 'A deemed rate is what a supplier charges when there\'s no fixed-term contract in place — either because you\'ve moved into a site without switching, or a contract has expired. Deemed rates are typically 40–80% above what a negotiated contract would cost, and suppliers have no obligation to tell you you\'re on one.' },
            { q: 'What are DUoS and TUoS charges?', a: 'Distribution Use of System (DUoS) and Transmission Use of System (TUoS) are network charges that cover the cost of moving electricity to your site. They\'re pass-through charges — but the rate bands, time-of-use structure, and whether they\'re being applied correctly are all things we check during an audit.' },
            { q: 'Can you help with half-hourly metered sites?', a: 'Yes, and HH sites are where we typically find the most savings. HH data lets us analyse your demand profile in detail — identifying peak demand, reactive power issues, and whether your agreed capacity is set correctly. Incorrectly set capacity charges alone can account for 5–12% of your total electricity spend.' },
            { q: 'How long does a commercial electricity tender take?', a: 'The initial audit takes 48–72 hours. The tender process typically runs for 5–10 working days depending on the number of sites and complexity. A straightforward single-site switch is usually complete within 3 weeks from your first call.' },
            { q: 'Do you cover renewable electricity tariffs?', a: 'Yes. If you have sustainability commitments or reporting requirements, we can source tariffs with REGO certificates. We\'ll show you the cost difference transparently so you can make the call based on your own priorities — not ours.' },
            { q: 'What happens if you don\'t find any savings?', a: 'It\'s rare — less than 4% of audits find nothing to improve. But if your current contract is already competitive, we\'ll tell you clearly, give you a written benchmark report, and set up renewal alerts so you\'re protected at the next break point.' },
          ].map(({ q, a }, i) => (
            <details data-reveal data-delay={String((i % 3) + 1)} class="group py-5 cursor-pointer list-none" style="list-style: none;">
              <summary class="flex items-center justify-between gap-4 font-heading font-semibold text-brand-navy text-[15px] tracking-[-0.02em] select-none list-none">
                {q}
                <div class="w-6 h-6 rounded-full border border-black/10 flex items-center justify-center flex-shrink-0 group-open:bg-brand-teal group-open:border-brand-teal transition-colors duration-200">
                  <svg class="w-3 h-3 text-brand-gray group-open:text-white group-open:rotate-45 transition-all duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                </div>
              </summary>
              <p class="text-brand-gray text-[13.5px] leading-relaxed mt-3 max-w-[560px]">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Related services ───────────────────────────────── -->
  <section class="py-20 bg-brand-off-white border-t border-black/6">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">
      <p data-reveal class="eyebrow mb-8">Other Services</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { name: 'Gas', href: '/services/gas', saving: '£4,200 avg. saving', img: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=600&q=75' },
          { name: 'Water', href: '/services/water', saving: '£1,600 avg. saving', img: 'https://images.unsplash.com/photo-1548407260-da850faa41e3?auto=format&fit=crop&w=600&q=75' },
          { name: 'Waste', href: '/services/waste', saving: '35% avg. reduction', img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=600&q=75' },
          { name: 'Asset Management', href: '/services/asset-management', saving: '18% efficiency gain', img: 'https://images.unsplash.com/photo-1581092795360-fd1ca04f0952?auto=format&fit=crop&w=600&q=75' },
        ].map(({ name, href, saving, img }, i) => (
          <a
            data-reveal
            data-delay={String(i + 1)}
            href={href}
            class="card-lift group relative rounded-xl overflow-hidden block"
            style="height: 180px;"
          >
            <img src={img} alt={name} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(6,16,26,0.90) 0%, rgba(6,16,26,0.35) 60%, transparent 100%);"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <div class="font-heading font-bold text-white text-[1rem] tracking-[-0.02em]">{name}</div>
              <div class="text-brand-teal text-[11.5px] font-semibold mt-0.5">{saving}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA / Contact ──────────────────────────────────── -->
  <section id="contact" class="relative py-28 overflow-hidden bg-brand-navy">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-[700px] h-[500px] bg-brand-teal/6 rounded-full blur-[150px]"></div>
      <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.8) 1px, transparent 0); background-size: 28px 28px;"></div>
    </div>

    <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="grid lg:grid-cols-2 gap-20 items-start">

        <!-- Left -->
        <div>
          <p data-reveal class="eyebrow" style="color: rgba(59,169,165,0.7)">Free Electricity Audit</p>
          <h2 data-reveal data-delay="1" class="font-heading font-bold text-white tracking-[-0.038em] leading-[1.0] mb-4" style="font-size: clamp(2.4rem, 5vw, 4.5rem);">
            Send us your<br />latest electricity bill.
          </h2>
          <p data-reveal data-delay="2" class="text-white/50 text-[14.5px] leading-relaxed max-w-[380px] mb-10">
            That's all we need. We'll come back within 24 hours with a clear picture of what you're paying versus what you should be paying.
          </p>
          <div data-reveal data-delay="3" class="space-y-3">
            {[
              'Free audit, no obligation',
              'Response within one business day',
              'Named account manager from day one',
              'We handle all supplier admin',
            ].map(item => (
              <div class="flex items-center gap-3 text-white/50 text-[13.5px]">
                <svg class="w-3.5 h-3.5 text-brand-teal flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                {item}
              </div>
            ))}
          </div>

          <!-- Phone -->
          <div data-reveal data-delay="4" class="flex items-center gap-3 mt-10 pt-8 border-t border-white/8">
            <div class="w-10 h-10 rounded-xl bg-brand-teal/15 border border-brand-teal/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <a href="tel:08001234567" class="font-heading font-bold text-white text-[1.1rem] tracking-[-0.02em] hover:text-brand-teal transition-colors">0800 123 4567</a>
              <p class="text-white/35 text-[12px]">Mon–Fri, 8am–6pm</p>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div data-reveal="right">
          <form class="p-8 rounded-2xl bg-white space-y-4" onsubmit="return false;">
            <h3 class="font-heading font-bold text-brand-navy text-[1.15rem] tracking-[-0.02em] mb-1">Request your free electricity audit</h3>
            <p class="text-brand-gray text-[13px] mb-5">We'll come back within one business day.</p>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">First name</label>
                <input type="text" placeholder="James" class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all" />
              </div>
              <div>
                <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">Last name</label>
                <input type="text" placeholder="Thompson" class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all" />
              </div>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">Business email</label>
              <input type="email" placeholder="james@company.co.uk" class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all" />
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">Company name</label>
              <input type="text" placeholder="Acme Ltd" class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all" />
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">Number of sites</label>
              <select class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all appearance-none cursor-pointer bg-white">
                <option value="">Select</option>
                <option>1 site</option>
                <option>2–5 sites</option>
                <option>6–15 sites</option>
                <option>16+ sites</option>
              </select>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">Annual electricity spend (approx.)</label>
              <select class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all appearance-none cursor-pointer bg-white">
                <option value="">Select a range</option>
                <option>Under £10,000/year</option>
                <option>£10k – £50k/year</option>
                <option>£50k – £200k/year</option>
                <option>£200k+/year</option>
              </select>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-brand-navy mb-1.5">Half-hourly metered? <span class="font-normal text-brand-gray-light">(if known)</span></label>
              <select class="w-full px-3.5 py-3 rounded-lg border border-black/12 text-brand-navy text-[13.5px] focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/10 transition-all appearance-none cursor-pointer bg-white">
                <option value="">Select</option>
                <option>Yes — HH metered</option>
                <option>No — non-HH</option>
                <option>Not sure</option>
              </select>
            </div>
            <button type="submit" class="btn-primary w-full justify-center py-3.5 text-[14px]">
              Request free audit
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
            <p class="text-center text-brand-gray-light text-[12px]">No obligation. No spam. Response within one business day.</p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @keyframes kenBurns {
    0%   { transform: scale(1.0); }
    100% { transform: scale(1.08); }
  }
  .hero-kenburns {
    animation: kenBurns 22s ease-in-out infinite alternate;
    will-change: transform;
  }
  details summary::-webkit-details-marker { display: none; }
  details summary { marker: none; }
</style>
