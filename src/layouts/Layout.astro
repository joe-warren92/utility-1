---
import criticalCss from '../styles/critical.css?inline';
import mainStylesUrl from '../styles/main.css?url';
import { getImage } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string | ImageMetadata;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  preloadImage?: ImageMetadata;
  preloadImageSizes?: string;
  preloadImageWidths?: number[];
}

const {
  title = 'Utility 1 - Commercial Utilities Made Simple',
  description = 'Utility 1 handles the complexity of your commercial utilities so you can focus on running your business. Gas, electric, water and waste, all under one roof.',
  canonical,
  image = '/opengraph.jpg',
  type = 'website',
  publishedTime,
  modifiedTime,
  jsonLd,
  preloadImage,
  preloadImageSizes = '100vw',
  preloadImageWidths = [640, 960, 1280, 1440, 1600],
} = Astro.props;

const siteUrl = Astro.site ?? Astro.url.origin;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl).href;
const imagePath = typeof image === 'string' ? image : image.src;
const imageUrl = new URL(imagePath, siteUrl).href;
const structuredData = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const preloadSources = preloadImage
  ? await Promise.all(
      preloadImageWidths.map((width) =>
        getImage({
          src: preloadImage,
          width,
          format: 'avif',
        })
      )
    )
  : [];
const preloadSrcset = preloadSources.map((source, index) => `${source.src} ${preloadImageWidths[index]}w`).join(', ');
const preloadHref = preloadSources[Math.min(preloadSources.length - 1, 3)]?.src;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    {preloadHref && (
      <link
        rel="preload"
        as="image"
        href={preloadHref}
        imagesrcset={preloadSrcset}
        imagesizes={preloadImageSizes}
        fetchpriority="high"
      />
    )}
    <style is:inline set:html={criticalCss} />
    <link rel="preload" href={mainStylesUrl} as="style" onload="this.onload=null;this.setAttribute('rel','stylesheet')" />
    <noscript><link rel="stylesheet" href={mainStylesUrl} /></noscript>
    {structuredData.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />

    <script>
      (() => {
        const motionWindow = window as Window & { __utilityMotionReady?: boolean };
        if (motionWindow.__utilityMotionReady) return;
        motionWindow.__utilityMotionReady = true;

        let revealObserver: IntersectionObserver | undefined;
        const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

        const initialiseReveals = () => {
          revealObserver?.disconnect();

          const revealElements = document.querySelectorAll('[data-reveal]');

          if (reducedMotionQuery.matches) {
            revealElements.forEach((el) => el.classList.add('is-visible'));
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
          );

          revealObserver = observer;

          revealElements.forEach((el) => {
            el.classList.remove('is-visible');
            observer.observe(el);
          });
        };

        const initialiseStaticForms = () => {
          document.querySelectorAll<HTMLFormElement>('[data-static-form]').forEach((form) => {
            if (form.dataset.staticFormReady === 'true') return;
            form.dataset.staticFormReady = 'true';
            form.addEventListener('submit', (event) => {
              event.preventDefault();
            });
          });
        };

        const closeMobileMenu = () => {
          const nav = document.getElementById('nav');
          const menu = document.getElementById('mobile-menu');
          const toggle = document.getElementById('mobile-menu-toggle');
          if (!nav || !menu || !toggle) return;
          menu.hidden = true;
          nav.classList.remove('site-header--open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open menu');
        };

        const initialisePage = () => {
          closeMobileMenu();
          initialiseReveals();
          initialiseStaticForms();
        };

        document.addEventListener('astro:before-preparation', () => {
          document.documentElement.classList.add('is-navigating');
        });

        document.addEventListener('astro:after-swap', () => {
          document.documentElement.classList.remove('is-navigating');
        });
        document.addEventListener('astro:page-load', initialisePage);
        initialisePage();
      })();
    </script>
  </body>
</html>
