---
import ServicePage from '../../components/ServicePage.astro';
import {
  distributionCentreExterior,
  siteEnergyAudit,
  stockroomInventory,
  warehouseDeskOperations,
  warehouseRacking,
  wasteCollectionTrucks,
} from '../../assets/images';

const benefits = [
  { title: 'Full electricity contract audit', copy: 'We benchmark your unit rate, standing charge, capacity charges and pass-through levies against live market rates. Most audits surface 15-30% in addressable overspend within 48 hours.' },
  { title: 'Half-hourly data analysis', copy: 'For HH-metered sites, we analyse your consumption profile to identify demand peaks, reactive power charges and whether your capacity limit is correctly set.' },
  { title: 'Supplier tender and negotiation', copy: 'We take your verified data to our panel of pre-qualified electricity suppliers, including suppliers you will not find on comparison sites, and run a genuine competitive tender.' },
  { title: 'Renewal management and monitoring', copy: 'We track your contract end dates and alert you six months in advance every time. No site will quietly roll onto a deemed rate again.' },
];

const commonProblems = [
  { quote: '"We had no idea what reactive power charges even were."', answer: 'Reactive power penalties are added when your power factor falls below a threshold. They are legal, but often fixable with power factor correction.' },
  { quote: '"Our unit rate looks fine but the bill keeps climbing."', answer: 'Unit rates are only one part of the bill. DUoS, TUoS and BSuoS are pass-through charges that can be structured better or checked for errors.' },
  { quote: '"We moved into a new site and took the existing electricity supply."', answer: 'Deemed rates on inherited supplies can be far above market. Many businesses do not realise they have been on one for months.' },
  { quote: '"The meter profile class does not match how we actually use electricity."', answer: 'Being on the wrong profile class means paying distribution charges based on an incorrect pattern. Reclassification can deliver permanent savings.' },
  { quote: '"We got a surprise bill for a period we thought was covered."', answer: 'Electricity billing errors around estimated reads and supply start or end dates are common. We identify and dispute these as part of every audit.' },
  { quote: '"Nobody warned us when our electricity contract ended."', answer: 'Many suppliers do not make renewal risk obvious. We give every managed client a six-month advance alert, every time.' },
];

const process = [
  { number: '01', title: 'Send us your latest electricity bill', copy: 'That is all we need to start. We can usually identify savings within 24 hours of receiving your current contract details and a recent invoice.', timeline: '24 hours' },
  { number: '02', title: 'We audit every charge', copy: 'Unit rate, standing charge, capacity, DUoS, TUoS, BSuoS, CCL and reactive power are checked against the current market.', timeline: '2-3 days' },
  { number: '03', title: 'We go to market on your behalf', copy: 'With verified consumption data and corrected profile information, we run a competitive tender with our pre-qualified supplier panel.', timeline: '1-2 weeks' },
  { number: '04', title: 'New contract. We handle the admin.', copy: 'Paperwork, meter registration, supply start notifications and final billing from the old supplier are handled by us.', timeline: '1-2 weeks' },
];

const faqs = [
  { question: 'What is a deemed rate and why does it matter?', answer: 'A deemed rate is what a supplier charges when there is no fixed-term contract in place. It is often much higher than a negotiated contract.' },
  { question: 'What are DUoS and TUoS charges?', answer: 'They are network charges covering the cost of moving electricity to your site. We check whether the rate bands and application are correct.' },
  { question: 'Can you help with half-hourly metered sites?', answer: 'Yes. HH data lets us analyse your demand profile in detail and often reveals capacity, peak demand or reactive power issues.' },
  { question: 'How long does a commercial electricity tender take?', answer: 'The initial audit usually takes 48-72 hours. The tender process often takes 5-10 working days depending on site count and complexity.' },
  { question: 'Do you cover renewable electricity tariffs?', answer: 'Yes. We can source tariffs with REGO certificates and show the cost difference clearly.' },
  { question: 'What happens if you do not find any savings?', answer: 'If your current contract is already competitive, we will tell you clearly and set up renewal alerts for the next break point.' },
];

const related = [
  { name: 'Gas', href: '/services/gas', saving: '£4,200 avg. saving', image: siteEnergyAudit },
  { name: 'Water', href: '/services/water', saving: '£1,600 avg. saving', image: distributionCentreExterior },
  { name: 'Waste', href: '/services/waste', saving: '35% avg. reduction', image: wasteCollectionTrucks },
  { name: 'Asset Management', href: '/services/asset-management', saving: '18% efficiency gain', image: stockroomInventory },
];
---

<ServicePage
  pageTitle="Commercial Electricity Contracts | Utility 1 - Cut Your Electricity Costs by Up to 24%"
  pageDescription="We audit your commercial electricity contracts, identify hidden charges, and renegotiate on your behalf. Average saving £7,800 per year. Free audit, no obligation."
  title="Your electricity bill"
  accent="has more in it than you think."
  eyebrow="Commercial Electricity"
  breadcrumb="Commercial Electricity"
  description="Pass-through charges, reactive power penalties, wrong profile classes and deemed rates can make electricity bills hard to read. We check every line, benchmark every charge, and fix what is wrong."
  image={warehouseDeskOperations}
  ctaLabel="Get a free electricity audit"
  stats={[
    { value: '24%', label: 'avg. electricity cost reduction' },
    { value: '£7,800', label: 'avg. annual saving' },
    { value: '600+', label: 'electricity audits completed' },
  ]}
  problemStats={[
    { value: '3 in 10', label: 'businesses are on the wrong electricity meter profile class' },
    { value: '£9,200', label: 'average annual overspend on electricity before audit' },
    { value: '18 months', label: 'average time a new supply sits on a deemed rate' },
    { value: '67%', label: 'of commercial electricity bills contain at least one billing issue' },
  ]}
  whatWeDoTitle="We go through your<br />electricity bill<br />line by line."
  whatWeDoCopy="Most businesses only look at the headline unit rate. We look at everything because that is where the real overspend hides. No charge, no obligation until we find savings worth pursuing."
  benefits={benefits}
  featureImage={siteEnergyAudit}
  featureImageAlt="Commercial electrical switchgear"
  auditCard={{ eyebrow: 'Recent electricity audit', value: '£11,400', copy: 'recovered from a wrong capacity charge', note: '14 months back-billed' }}
  commonProblemsEyebrow="Common Electricity Problems"
  commonProblemsTitle="We hear this every week."
  commonProblems={commonProblems}
  caseStudy={{
    eyebrow: 'Electricity Case Study',
    title: 'A retail chain was paying the wrong rate on two of its eight sites.',
    copy: [
      'A national fashion retailer came to us with eight sites across three electricity contracts with two suppliers. Finance had flagged that bills were higher than expected but could not identify the problem.',
      'Our audit found two sites on the wrong meter profile class. One site had also been on a deemed rate for eleven months following a store refurbishment.',
      'We corrected the profile classes, recovered back-billing on the deemed rate, and ran a full market tender across all eight sites. New contracts were live within four weeks.',
    ],
    quote: '"The profile class issue alone was worth more than we expected. Something that had been wrong for years, fixed in a week." - Finance Director',
    image: warehouseRacking,
    imageAlt: 'Retail chain electricity audit',
    savingLabel: 'Annual electricity saving',
    savingValue: '£27,400',
    savingNote: '24%',
    stats: [
      { value: '8', label: 'sites audited' },
      { value: '£27,400', label: 'annual saving' },
      { value: '4 weeks', label: 'to completion' },
    ],
    ctaLabel: 'Start your electricity audit',
  }}
  processTitle="From first contact to<br />savings in four weeks."
  process={process}
  faqs={faqs}
  related={related}
  contactEyebrow="Free Electricity Audit"
  contactTitle="Send us your latest electricity bill."
  contactCopy="That is all we need. We will come back within 24 hours with a clear picture of what you are paying versus what you should be paying."
  formTitle="Request your free electricity audit"
  spendLabel="Annual electricity spend (approx.)"
  meterField
/>
