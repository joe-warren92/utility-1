---
import ServicePage from '../../components/ServicePage.astro';
import {
  distributionCentreExterior,
  siteEnergyAudit,
  stockroomInventory,
  warehouseDeskOperations,
  warehouseRacking,
  wasteCollectionTrucks,
} from '../../assets/images';

const benefits = [
  { title: 'Contract audit and benchmarking', copy: 'We pull your current rates, unit prices, standing charges and exit terms, then benchmark everything against live market pricing. You get a clear picture of exactly what you are overpaying.' },
  { title: 'Supplier negotiation', copy: 'We have relationships with major UK gas suppliers. We go to market on your behalf, run a competitive tender, and only recommend switching if the numbers genuinely stack up.' },
  { title: 'Half-hourly data analysis', copy: 'For larger sites, we analyse half-hourly consumption data to identify demand spikes, inefficiencies and tariff mismatches, then use that to negotiate a better-fit contract.' },
  { title: 'Renewal management', copy: 'We track every renewal date across your portfolio and contact you six months before each deadline. You will never roll onto an out-of-contract rate again.' },
];

const commonProblems = [
  { quote: '"Our gas contract auto-renewed and we did not notice for 18 months."', answer: 'Standard out-of-contract rates can be 30-50% above what you would get on a fixed term. We track your renewal dates and move before they hit.' },
  { quote: '"We have six sites. Each one is with a different supplier on different terms."', answer: 'We consolidate multi-site portfolios onto a preferred supplier with clearer terms and one point of contact, usually at a lower blended rate.' },
  { quote: '"Our gas bill went up 40% and no one at the supplier could explain it."', answer: 'Billing errors, incorrect meter reads and unexplained charges are common. We audit your invoices line by line and recover what you are owed.' },
  { quote: '"We are on a fixed contract but it expires in three months and we have not started looking."', answer: 'Three months is tight but workable. We can run a full market tender in 2-3 weeks. The earlier you come to us, the more leverage we have.' },
  { quote: '"We moved premises and inherited the previous tenant gas setup."', answer: 'Deemed rates on inherited contracts are typically the highest available. We get you onto a proper commercial agreement quickly.' },
  { quote: '"I do not have time to deal with this because we have enough on."', answer: 'That is exactly why we exist. You send your latest bill, we do the work, then come back with a clear proposal.' },
];

const process = [
  { number: '01', title: 'Send us your latest gas bill', copy: 'That is all we need to start. No lengthy forms and no long calls. We can usually identify savings within 24 hours of receiving your current contract details.', timeline: '24 hours' },
  { number: '02', title: 'We audit and benchmark', copy: 'We run your rates against live market pricing from major UK gas suppliers. You get a clear, no-jargon summary showing exactly what you are overpaying and what we can do about it.', timeline: '2-3 days' },
  { number: '03', title: 'We go to market on your behalf', copy: 'If the numbers stack up, we run a competitive tender with pre-qualified suppliers. We negotiate, not you. You choose from a shortlist of verified offers.', timeline: '1-2 weeks' },
  { number: '04', title: 'New contract. We handle the admin.', copy: 'Paperwork, supplier liaison, meter reads and final billing from the old supplier are handled by us. Your team only needs to approve the new agreement.', timeline: '1-2 weeks' },
];

const faqs = [
  { question: 'Is the audit really free?', answer: 'Yes. We audit your gas contracts, benchmark them against the market, and show you the potential savings before you have committed to anything.' },
  { question: 'How long does it take to switch gas suppliers?', answer: 'Typically 2-4 weeks from signing the new contract to your first bill with the new supplier. We handle the logistics, meter reads and account closure.' },
  { question: 'Will switching disrupt our gas supply?', answer: 'No. The physical gas supply does not change because it comes through the same pipes. Only the billing relationship changes.' },
  { question: 'We are mid-contract. Can you still help?', answer: 'Yes. We review the exit terms and calculate whether the savings justify any early exit fees. If not, we put a plan in place for your next renewal window.' },
  { question: 'Do you only work with large businesses?', answer: 'No. We work with businesses spending from a few thousand pounds a year through to large multi-site portfolios.' },
  { question: 'How do you make money if the audit is free?', answer: 'We may earn commission from suppliers when we successfully negotiate a new contract. That is disclosed clearly before anything is signed.' },
];

const related = [
  { name: 'Electricity', href: '/services/electric', saving: '£5,800 avg. saving', image: warehouseDeskOperations },
  { name: 'Water', href: '/services/water', saving: '£1,600 avg. saving', image: distributionCentreExterior },
  { name: 'Waste', href: '/services/waste', saving: '35% avg. reduction', image: wasteCollectionTrucks },
  { name: 'Asset Management', href: '/services/asset-management', saving: '18% efficiency gain', image: stockroomInventory },
];
---

<ServicePage
  pageTitle="Commercial Gas Contracts | Utility 1 - Cut Your Gas Costs by Up to 22%"
  pageDescription="We audit your commercial gas contracts, find overcharges, and renegotiate on your behalf. Average saving £4,200 per year. Free audit, no obligation."
  title="Stop paying over"
  accent="the odds for gas."
  eyebrow="Commercial Gas"
  breadcrumb="Commercial Gas"
  description="Most commercial gas contracts roll onto out-of-contract rates and stay there for years. We find what you are overpaying, renegotiate the whole thing, and manage your renewals so it never happens again."
  image={siteEnergyAudit}
  ctaLabel="Get a free gas audit"
  stats={[
    { value: '22%', label: 'avg. gas cost reduction' },
    { value: '£4,200', label: 'avg. annual saving' },
    { value: '500+', label: 'gas audits completed' },
  ]}
  problemStats={[
    { value: '4 in 10', label: 'businesses are on out-of-contract gas rates right now' },
    { value: '£6,800', label: 'average annual overspend on commercial gas before audit' },
    { value: '3 years', label: 'average time a business stays on the same rolling contract' },
    { value: '82%', label: 'of our gas clients find savings in the first audit' },
  ]}
  whatWeDoTitle="We find the overcharges.<br />Then we fix them."
  whatWeDoCopy="We start with a complete audit of your existing gas contracts, meter by meter and site by site. No charge, no obligation. We only proceed if we find savings worth pursuing."
  benefits={benefits}
  featureImage={distributionCentreExterior}
  featureImageAlt="Commercial gas infrastructure"
  auditCard={{ eyebrow: 'Recent gas audit', value: '£18,200', copy: 'recovered for a food manufacturer', note: '22% contract reduction' }}
  commonProblemsEyebrow="Common Gas Problems"
  commonProblemsTitle="We hear this every week."
  commonProblems={commonProblems}
  caseStudy={{
    eyebrow: 'Gas Case Study',
    title: 'A logistics operator had been on the same gas contract for four years.',
    copy: [
      'When they first called us, they had 14 sites across the Midlands and South East. All were on separate gas contracts. Three had already rolled onto out-of-contract rates without anyone noticing.',
      'Our audit took five working days. We found £22,400 in annual overspend across their portfolio, including rolled rates, outdated standing charges and one site that had been on deemed rates for eight months after a lease renewal.',
      'We renegotiated all 14 contracts with two preferred suppliers, consolidated invoicing, and set up proactive renewal alerts. The whole process took four weeks from first contact to new contracts live.',
    ],
    quote: '"We had been meaning to look at this for two years. Utility 1 sorted everything in a month and saved us more than we expected. Should have done it sooner." - Operations Director',
    image: warehouseRacking,
    imageAlt: 'Distribution warehouse',
    savingLabel: 'Annual gas saving',
    savingValue: '£22,400',
    savingNote: '22%',
    stats: [
      { value: '14', label: 'sites audited' },
      { value: '£22,400', label: 'annual saving' },
      { value: '4 weeks', label: 'to completion' },
    ],
    ctaLabel: 'Start your gas audit',
  }}
  processTitle="From first contact to<br />savings in four weeks."
  process={process}
  faqs={faqs}
  related={related}
  contactEyebrow="Free Gas Audit"
  contactTitle="Send us your latest gas bill."
  contactCopy="That is all we need. We will come back within 24 hours with a clear picture of what you are paying versus what you should be paying."
  formTitle="Request your free gas audit"
  spendLabel="Annual gas spend (approx.)"
/>
