---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Commercial Gas Contracts | Utility 1 — Cut Your Gas Costs by Up to 22%"
  description="We audit your commercial gas contracts, find the overcharges, and renegotiate on your behalf. Average saving £4,200 per year. Free audit, no obligation."
>
  <Nav />

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="relative flex flex-col overflow-hidden bg-[#06101a]" style="min-height: 80vh;">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1800&q=85"
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center hero-kenburns"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(6,16,26,0.97) 0%, rgba(6,16,26,0.88) 50%, rgba(6,16,26,0.50) 100%);"></div>
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(6,16,26,0.80) 0%, transparent 55%);"></div>
    </div>

    <div class="relative flex flex-col justify-center flex-1" style="padding-top: 130px; padding-bottom: 80px;">
      <div class="max-w-[1360px] mx-auto px-8 xl:px-12 w-full">

        <!-- Breadcrumb -->
        <div data-reveal class="flex items-center gap-2 text-white/35 text-[12px] mb-8">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/#services" class="hover:text-white/60 transition-colors">Services</a>
          <span>/</span>
          <span class="text-brand-teal">Commercial Gas</span>
        </div>

        <div class="max-w-[760px]">
          <p data-reveal class="eyebrow">Commercial Gas</p>
          <h1 data-reveal data-delay="1" class="font-heading font-bold text-white tracking-[-0.038em] leading-[1.0] mb-5" style="font-size: clamp(2.8rem, 6vw, 6rem);">
            Stop paying over<br />the odds for gas.
          </h1>
          <p data-reveal data-delay="2" class="text-white/55 leading-relaxed max-w-[520px] mb-10" style="font-size: 1.1rem;">
            Most commercial gas contracts roll onto out-of-contract rates and stay there for years. We find what you're overpaying, renegotiate the whole thing, and manage your renewals so it never happens again.
          </p>

          <div data-reveal data-delay="3" class="flex flex-wrap items-center gap-4 mb-12">
            <a href="#contact" class="btn-primary" style="font-size: 15px; padding: 15px 32px;">
              Get a free gas audit
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:08001234567" class="btn-ghost" style="font-size: 14px; padding: 14px 26px;">
              0800 123 4567
            </a>
          </div>

          <!-- Inline proof stats -->
          <div data-reveal data-delay="4" class="flex flex-wrap gap-8">
            {[
              { v: '22%', l: 'avg. gas cost reduction' },
              { v: '£4,200', l: 'avg. annual saving' },
              { v: '500+', l: 'gas audits completed' },
            ].map(({ v, l }) => (
              <div>
                <div class="font-heading font-bold text-white leading-none tracking-[-0.03em]" style="font-size: 1.5rem;">{v}</div>
                <div class="text-white/35 text-[11px] uppercase tracking-[0.1em] mt-1">{l}</div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Problem strip ──────────────────────────────────── -->
  <section class="bg-white border-b border-black/6 py-10">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-10 divide-y-2 lg:divide-y-0 lg:divide-x divide-black/6">
        {[
          { h: '4 in 10', sub: 'businesses are on out-of-contract gas rates right now' },
          { h: '£6,800', sub: 'average annual overspend on commercial gas before audit' },
          { h: '3 years', sub: 'average time a business stays on the same rolling contract' },
          { h: '82%', sub: 'of our gas clients find savings in the first audit' },
        ].map(({ h, sub }) => (
          <div class="pt-4 lg:pt-0 lg:pl-10 first:pl-0 first:pt-0">
            <div class="font-heading font-bold text-brand-teal leading-none tracking-[-0.04em] mb-1.5" style="font-size: 2rem;">{h}</div>
            <p class="text-brand-gray text-[13px] leading-relaxed">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── What we do ─────────────────────────────────────── -->
  <section class="py-28 bg-brand-off-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[700px] h-[500px] bg-brand-teal/3 rounded-full blur-[180px] translate-x-1/3 pointer-events-none"></div>
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

      <div class="grid lg:grid-cols-2 gap-20 items-center">

        <div>
          <p data-reveal class="eyebrow">What We Do</p>
          <h2 data-reveal data-delay="1" class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02] mb-5" style="font-size: clamp(2.2rem, 4vw, 3.5rem);">
            We find the overcharges.<br />Then we fix them.
          </h2>
          <p data-reveal data-delay="2" class="text-brand-gray text-[14.5px] leading-relaxed max-w-[420px] mb-10">
            We start with a complete audit of your existing gas contracts — meter by meter, site by site. No charge, no obligation. We only proceed if we find savings worth pursuing.
          </p>

          <div class="space-y-5">
            {[
              {
                title: 'Contract audit & benchmarking',
                body: 'We pull your current rates, unit prices, standing charges and exit terms, then benchmark everything against live market pricing. You get a clear picture of exactly what you\'re overpaying.',
              },
              {
                title: 'Supplier negotiation',
                body: 'We have relationships with all major UK gas suppliers. We go to market on your behalf, run a competitive tender, and only recommend switching if the numbers genuinely stack up.',
              },
              {
                title: 'Half-hourly data analysis',
                body: 'For larger sites, we analyse half-hourly consumption data to identify demand spikes, inefficiencies, and tariff mismatches — then use that to negotiate a better-fit contract.',
              },
              {
                title: 'Renewal management',
                body: 'We track every renewal date across your portfolio and contact you 6 months before each deadline. You will never roll onto an out-of-contract rate again.',
              },
            ].map(({ title, body }, i) => (
              <div data-reveal data-delay={String(i + 1)} class="flex gap-4 p-5 rounded-xl border border-black/6 bg-white hover:border-brand-teal/25 transition-colors duration-300">
                <div class="w-5 h-5 rounded-full bg-brand-teal/15 border border-brand-teal/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <p class="font-heading font-semibold text-brand-navy text-[14px] tracking-[-0.02em] mb-1">{title}</p>
                  <p class="text-brand-gray text-[13px] leading-relaxed">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: image + floating card -->
        <div data-reveal="right" class="relative">
          <div class="relative rounded-2xl overflow-hidden" style="height: 540px;">
            <img
              src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=900&q=80"
              alt="Commercial gas infrastructure"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-br from-brand-navy/30 via-transparent to-brand-navy/20"></div>
          </div>
          <!-- Floating result card -->
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-6 shadow-[0_8px_48px_rgba(15,25,35,0.12)]" style="min-width: 220px;">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-brand-gray-light mb-1">Recent gas audit</div>
            <div class="font-heading font-bold text-brand-navy leading-none tracking-[-0.04em]" style="font-size: 2.4rem;">£18,200</div>
            <div class="text-brand-gray text-[12px] mt-1">recovered for a food manufacturer</div>
            <div class="text-brand-teal text-[11px] font-semibold mt-2">22% contract reduction</div>
          </div>
          <!-- Top badge -->
          <div class="absolute top-6 -right-4 bg-brand-teal rounded-xl p-4 shadow-[0_8px_32px_rgba(59,169,165,0.35)]">
            <div class="text-white/75 text-[10px] uppercase tracking-wider mb-1">First audit</div>
            <div class="font-heading font-bold text-white leading-none tracking-[-0.03em]" style="font-size: 1.4rem;">Free</div>
            <div class="text-white/60 text-[11px] mt-0.5">No obligation</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Common problems ────────────────────────────────── -->
  <section class="py-24 bg-brand-navy relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 80px 80px;"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[500px] bg-brand-teal/5 rounded-full blur-[150px]"></div>

    <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="max-w-[640px] mb-14">
        <p data-reveal class="eyebrow" style="color: rgba(59,169,165,0.7)">Common Gas Problems</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-white tracking-[-0.035em] leading-[1.02]" style="font-size: clamp(2.2rem, 4vw, 3.5rem);">
          We hear this every week.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            q: '"Our gas contract auto-renewed and we didn\'t notice for 18 months."',
            a: 'Standard out-of-contract rates can be 30–50% above what you\'d get on a fixed term. We track your renewal dates and move before they hit.',
          },
          {
            q: '"We have six sites. Each one is with a different supplier on different terms."',
            a: 'We consolidate multi-site portfolios onto a single preferred supplier with unified terms and one point of contact — usually at a lower blended rate.',
          },
          {
            q: '"Our gas bill went up 40% and no one at the supplier could explain it."',
            a: 'Billing errors, incorrect meter reads, and unexplained charges are common. We audit your invoices line by line and recover what you\'re owed.',
          },
          {
            q: '"We\'re on a fixed contract but it expires in three months and we haven\'t started looking."',
            a: 'Three months is tight but workable. We can run a full market tender in 2–3 weeks. The earlier you come to us, the more leverage we have.',
          },
          {
            q: '"We moved premises and inherited the previous tenant\'s gas setup."',
            a: 'Deemed rates on inherited contracts are typically the highest available. We get you onto a proper commercial agreement within days.',
          },
          {
            q: '"I don\'t have time to deal with this — we\'ve got enough on."',
            a: 'That\'s exactly why we exist. You give us a copy of your latest bill. We do the rest and come back with a clear proposal.',
          },
        ].map(({ q, a }, i) => (
          <div
            data-reveal
            data-delay={String((i % 3) + 1)}
            class="group p-6 rounded-xl border border-white/7 hover:border-brand-teal/25 hover:bg-white/4 transition-all duration-300"
          >
            <p class="font-heading font-semibold text-white/80 text-[0.95rem] leading-snug italic mb-3 tracking-[-0.01em]">{q}</p>
            <div class="w-8 h-px bg-brand-teal/30 mb-3 group-hover:w-12 group-hover:bg-brand-teal transition-all duration-300"></div>
            <p class="text-white/40 text-[13px] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Case study ─────────────────────────────────────── -->
  <section class="py-28 bg-white relative overflow-hidden">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div data-reveal class="relative rounded-2xl overflow-hidden" style="height: 460px;">
          <img
            src="https://images.unsplash.com/photo-1553413077-190dd305871c?auto=format&fit=crop&w=900&q=80"
            alt="Distribution warehouse"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-brand-navy/20 to-transparent"></div>
          <!-- Savings callout -->
          <div class="absolute bottom-6 left-6 right-6">
            <div class="p-5 rounded-xl bg-brand-navy/90 backdrop-blur-sm border border-white/10">
              <div class="flex items-end justify-between">
                <div>
                  <div class="text-white/45 text-[10px] uppercase tracking-[0.1em] mb-1">Annual gas saving</div>
                  <div class="font-heading font-bold text-brand-teal leading-none tracking-[-0.04em]" style="font-size: 2.5rem;">£22,400</div>
                </div>
                <div class="text-right">
                  <div class="text-brand-teal font-semibold text-[1.1rem]">22%</div>
                  <div class="text-white/40 text-[11px]">contract reduction</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div data-reveal="right">
          <p class="eyebrow">Gas Case Study</p>
          <h2 class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02] mb-4" style="font-size: clamp(1.9rem, 3.5vw, 2.8rem);">
            A logistics operator had been on the same gas contract for four years.
          </h2>
          <div class="space-y-4 text-brand-gray text-[14px] leading-relaxed mb-8">
            <p>When they first called us, they had 14 sites across the Midlands and South East. All on separate gas contracts. Three had already rolled onto out-of-contract rates without anyone noticing.</p>
            <p>Our audit took five working days. We found £22,400 in annual overspend across their portfolio — a mixture of rolled rates, outdated standing charges, and one site that had been on deemed rates for eight months after a lease renewal.</p>
            <p>We renegotiated all 14 contracts with two preferred suppliers, consolidated invoicing, and set up proactive renewal alerts. The whole process took four weeks from first contact to new contracts live.</p>
            <p class="italic text-brand-navy/70">"We'd been meaning to look at this for two years. Utility 1 sorted everything in a month and saved us more than we expected. Should have done it sooner." — Operations Director</p>
          </div>

          <div class="flex flex-wrap gap-5 pt-6 border-t border-black/6 mb-8">
            {[
              { v: '14', l: 'sites audited' },
              { v: '£22,400', l: 'annual saving' },
              { v: '4 weeks', l: 'to completion' },
            ].map(({ v, l }) => (
              <div>
                <div class="font-heading font-bold text-brand-navy leading-none tracking-[-0.03em]" style="font-size: 1.5rem;">{v}</div>
                <div class="text-brand-gray-light text-[11px] uppercase tracking-[0.1em] mt-1">{l}</div>
              </div>
            ))}
          </div>

          <a href="#contact" class="btn-primary">
            Start your gas audit
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── How it works (gas-specific) ───────────────────── -->
  <section class="py-24 bg-brand-off-white relative overflow-hidden">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">

      <div class="max-w-[640px] mb-16">
        <p data-reveal class="eyebrow">The Process</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02]" style="font-size: clamp(2.2rem, 4vw, 3.5rem);">
          From first contact to<br />savings in four weeks.
        </h2>
      </div>

      <div class="space-y-0 divide-y divide-black/6">
        {[
          { n: '01', title: 'Send us your latest gas bill', body: 'That\'s all we need to start. No lengthy forms, no long calls. We can usually identify savings within 24 hours of receiving your current contract details.', time: '24 hours' },
          { n: '02', title: 'We audit and benchmark', body: 'We run your rates against live market pricing from all major UK gas suppliers. You get a clear, no-jargon summary showing exactly what you\'re overpaying and what we can do about it.', time: '2–3 days' },
          { n: '03', title: 'We go to market on your behalf', body: 'If the numbers stack up — and they usually do — we run a competitive tender with pre-qualified suppliers. We negotiate, not you. You choose from a shortlist of verified offers.', time: '1–2 weeks' },
          { n: '04', title: 'New contract. We handle the admin.', body: 'Paperwork, supplier liaison, meter reads, final billing from the old supplier. We handle all of it. Your team does nothing except sign the new agreement.', time: '1–2 weeks' },
        ].map(({ n, title, body, time }, i) => (
          <div
            data-reveal
            data-delay={String((i % 2) + 1)}
            class="group grid grid-cols-[80px_1fr_auto] items-center gap-6 lg:gap-12 py-8 hover:bg-white transition-colors duration-300 -mx-8 px-8 xl:-mx-12 xl:px-12 rounded-xl"
          >
            <div class="font-heading font-bold text-[2.8rem] text-black/7 group-hover:text-brand-teal/20 transition-colors leading-none tabular-nums tracking-[-0.04em]">{n}</div>
            <div>
              <h3 class="font-heading font-bold text-brand-navy text-[1.1rem] tracking-[-0.025em] mb-1.5 group-hover:text-brand-teal transition-colors duration-300">{title}</h3>
              <p class="text-brand-gray text-[13.5px] leading-relaxed max-w-[520px]">{body}</p>
            </div>
            <div class="hidden lg:flex flex-col items-end">
              <span class="text-[10px] uppercase tracking-[0.12em] text-brand-gray-light mb-1">Timeline</span>
              <span class="font-heading font-semibold text-brand-navy text-[14px]">{time}</span>
              <div class="w-8 h-px bg-brand-teal/40 mt-2 group-hover:w-14 group-hover:bg-brand-teal transition-all duration-300"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-20">

        <div class="lg:sticky lg:top-32 self-start">
          <p data-reveal class="eyebrow">FAQ</p>
          <h2 data-reveal data-delay="1" class="font-heading font-bold text-brand-navy tracking-[-0.035em] leading-[1.02] mb-5" style="font-size: clamp(2rem, 3.5vw, 3rem);">
            Questions we get asked every day.
          </h2>
          <p data-reveal data-delay="2" class="text-brand-gray text-[14px] leading-relaxed mb-8">
            Straight answers. No sales pitch.
          </p>
          <a href="#contact" class="btn-dark text-[13.5px]">Still have a question? Ask us.</a>
        </div>

        <div class="space-y-0 divide-y divide-black/6" id="faq">
          {[
            { q: 'Is the audit really free?', a: 'Yes. We audit your gas contracts, benchmark them against the market, and show you the potential savings — all before you\'ve committed to anything. We only earn a fee when we successfully save you money.' },
            { q: 'How long does it take to switch gas suppliers?', a: 'Typically 2–4 weeks from signing the new contract to your first bill with the new supplier. We handle all the logistics, meter reads, and final account closure with your existing supplier.' },
            { q: 'Will switching disrupt our gas supply?', a: 'No. The physical gas supply never changes — it all comes through the same pipes. Only the billing relationship changes. There is zero risk of disruption.' },
            { q: 'We\'re mid-contract. Can you still help?', a: 'Yes. We review the exit terms and calculate whether the savings justify any early exit fees. In most cases they do. If not, we put a plan in place to act at your next renewal window.' },
            { q: 'Do you only work with large businesses?', a: 'No. We work with businesses spending £2,000 to £2M+ on gas per year. The audit process is the same regardless of size, and we find savings at every level.' },
            { q: 'How do you make money if the audit is free?', a: 'We earn a commission from suppliers when we successfully negotiate a new contract on your behalf. That commission is always disclosed upfront, and it does not affect the price you pay.' },
          ].map(({ q, a }, i) => (
            <details data-reveal data-delay={String((i % 3) + 1)} class="group py-5 cursor-pointer list-none" style="list-style: none;">
              <summary class="flex items-center justify-between gap-4 font-heading font-semibold text-brand-navy text-[15px] tracking-[-0.02em] select-none list-none">
                {q}
                <div class="w-6 h-6 rounded-full border border-black/10 flex items-center justify-center flex-shrink-0 group-open:bg-brand-teal group-open:border-brand-teal transition-colors duration-200">
                  <svg class="w-3 h-3 text-brand-gray group-open:text-white group-open:rotate-45 transition-all duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                </div>
              </summary>
              <p class="text-brand-gray text-[13.5px] leading-relaxed mt-3 max-w-[560px]">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Related services ───────────────────────────────── -->
  <section class="py-20 bg-brand-off-white border-t border-black/6">
    <div class="max-w-[1360px] mx-auto px-8 xl:px-12">
      <p data-reveal class="eyebrow mb-8">Other Services</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { name: 'Electric', href: '/services/electric', saving: '£5,800 avg. saving', img: 'https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?auto=format&fit=crop&w=600&q=75' },
          { name: 'Water', href: '/services/water', saving: '£1,600 avg. saving', img: 'https://images.unsplash.com/photo-1548407260-da850faa41e3?auto=format&fit=crop&w=600&q=75' },
          { name: 'Waste', href: '/services/waste', saving: '35% avg. reduction', img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=600&q=75' },
          { name: 'Asset Management', href: '/services/asset-management', saving: '18% efficiency gain', img: 'https://images.unsplash.com/photo-1581092795360-fd1ca04f0952?auto=format&fit=crop&w=600&q=75' },
        ].map(({ name, href, saving, img }, i) => (
          <a
            data-reveal
            data-delay={String(i + 1)}
            href={href}
            class="card-lift group relative rounded-xl overflow-hidden block"
            style="height: 180px;"
          >
            <img src={img} alt={name} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(6,16,26,0.90) 0%, rgba(6,16,26,0.35) 60%, transparent 100%);"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <div class="font-heading font-bold text-white text-[1rem] tracking-[-0.02em]">{name}</div>
              <div class="text-brand-teal text-[11.5px] font-semibold mt-0.5">{saving}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA / Contact ──────────────────────────────────── -->
  <section id="contact" class="relative py-28 overflow-hidden bg-brand-navy">
    <div class="absolute inset-0">
