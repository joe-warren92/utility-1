---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import {
  distributionCentreExterior,
  recyclingMaterials,
  siteEnergyAudit,
  warehouseDeskOperations,
  warehouseRacking,
} from '../../assets/images';

const heroMetrics = [
  { value: '£45,000', label: 'Annual saving' },
  { value: '28%', label: 'Cost reduction' },
  { value: '14', label: 'Sites consolidated' },
  { value: '4 weeks', label: 'Delivery time' },
  { value: '6 years', label: 'Contracts unreviewed' },
];

const clientProfile = [
  { label: 'Sector', value: 'Logistics & Distribution' },
  { label: 'Sites', value: '14 across Midlands & South East' },
  { label: 'Employees', value: '340' },
  { label: 'Annual turnover', value: '£28M' },
  { label: 'Utilities covered', value: 'Gas, Electricity, Water' },
  { label: 'Previous reviews', value: 'None in 6 years' },
];

const timeline = [
  { step: 'Initial contact', time: 'Day 1' },
  { step: 'Full audit delivered', time: 'Day 5' },
  { step: 'Supplier tender', time: 'Weeks 2–3' },
  { step: 'Contracts agreed', time: 'Week 4' },
  { step: 'New billing live', time: 'Week 6' },
];

const challenges = [
  {
    number: '01',
    title: 'Out-of-contract rates on three sites',
    body: 'Three of the fourteen sites had rolled past their contract end dates onto out-of-contract "deemed" rates — 35–52% above standard market pricing at the time. This had been running undetected for between 4 and 18 months.',
    cost: '+£14,200/yr',
    costLabel: 'estimated overspend',
    image: warehouseRacking,
  },
  {
    number: '02',
    title: 'Fragmented supplier base, no visibility',
    body: 'With eleven different supplier accounts across gas and electricity, there was no consolidated view of spend. Two sites were duplicating standing charges due to an old meter setup that had never been corrected.',
    cost: '+£8,600/yr',
    costLabel: 'in avoidable charges',
    image: siteEnergyAudit,
  },
  {
    number: '03',
    title: 'Untendered water contract on a new site',
    body: 'A water contract accepted from the previous tenant at a new site had never been put out to tender. The rate was 28% above the current available market rate — discovered in the first 20 minutes of the audit.',
    cost: '+£4,100/yr',
    costLabel: 'on water alone',
    image: distributionCentreExterior,
  },
];

const approach = [
  {
    number: '01',
    title: 'Full portfolio audit (Days 1–5)',
    body: 'We gathered contracts, meter reads, and invoices for all 14 sites. Our team built a complete cost model — current rates versus market benchmark — for gas, electricity, and water across the whole estate.',
  },
  {
    number: '02',
    title: 'Immediate fixes first (Week 1)',
    body: 'While the full tender was being prepared, we immediately contacted the three suppliers running out-of-contract rates and negotiated interim "holding" rates to stop the bleeding. This saved approximately £1,100 during the tender process itself.',
  },
  {
    number: '03',
    title: 'Competitive tender across all utilities (Weeks 2–3)',
    body: 'We ran a full market tender with our pre-qualified supplier panel — seven gas suppliers, five electricity, two water. All site data had already been compiled so the process was fast. We presented a shortlist of three verified options.',
  },
  {
    number: '04',
    title: 'Contracts signed and administration handled (Week 4)',
    body: 'Once the client approved the recommended suppliers, we handled all paperwork, meter read coordination, and final settlement with the outgoing suppliers. The client\'s ops team spent approximately three hours on the entire process.',
  },
];

const resultStats = [
  { value: '£45,000', label: 'Total year-one saving', sub: 'across gas, electricity and water' },
  { value: '28%', label: 'Average cost reduction', sub: 'vs. pre-audit spend' },
  { value: '14 → 2', label: 'Supplier accounts', sub: 'consolidated from 14 to 2' },
  { value: '0', label: 'Hours of client admin', sub: 'in the entire switch process' },
];

const resultRows = [
  { utility: 'Gas (14 sites)', previous: '£89,400', next: '£71,200', saving: '£18,200', percent: '20%' },
  { utility: 'Electricity (14 sites)', previous: '£112,000', next: '£84,600', saving: '£27,400', percent: '24%' },
  { utility: 'Water (4 sites)', previous: '£14,600', next: '£11,200', saving: '£3,400', percent: '23%' },
  { utility: 'Admin time saved', previous: '2 days/month', next: '<1 hour/month', saving: 'c.£8,000', percent: 'est.' },
];

const outcomes = [
  {
    title: 'Renewal management active',
    body: 'All 14 sites now have proactive renewal alerts set 6 months in advance. No site will ever roll onto an out-of-contract rate again.',
  },
  {
    title: 'Consolidated reporting',
    body: 'One monthly invoice. One dashboard. Finance can now see cost-per-site, cost-per-unit, and year-on-year comparisons across the entire estate.',
  },
  {
    title: 'Finance time returned',
    body: 'The two days per month previously spent on utility reconciliation is now under one hour. That\'s roughly £8,000 of finance team time returned per year.',
  },
];

const moreCases = [
  {
    image: siteEnergyAudit,
    sector: 'Facilities Management',
    metric: '15 sites consolidated',
    title: 'Streamlining utility management for a multi-site FM operator',
    savings: '£32,000',
    href: '/case-studies/sterling-facilities',
  },
  {
    image: recyclingMaterials,
    sector: 'Manufacturing',
    metric: '35% waste reduction',
    title: 'Cutting waste management costs for an industrial manufacturer',
    savings: '£18,500',
    href: '/case-studies/industrial-manufacturer',
  },
];
---

<Layout
  title="National Distribution Group Case Study | Utility 1"
  description="How Utility 1 reduced utility costs by 28% across 14 logistics sites — saving £45,000 in year one. Full case study."
>
  <Nav />

  <main class="case-detail">
    <section class="case-detail-hero">
      <div class="case-detail-hero__media">
        <OptimizedImage
          src={distributionCentreExterior}
          alt="National distribution warehouse"
          class="case-detail-hero__image"
          loading="eager"
          fetchpriority="high"
        />
        <div class="case-detail-hero__overlay case-detail-hero__overlay--side"></div>
        <div class="case-detail-hero__overlay case-detail-hero__overlay--bottom"></div>
      </div>

      <div class="container case-detail-hero__content">
        <nav data-reveal class="breadcrumb case-detail-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/case-studies">Case Studies</a>
          <span>/</span>
          <span>National Distribution Group</span>
        </nav>

        <div class="case-detail-hero__grid">
          <div class="case-detail-hero__copy">
            <div data-reveal class="case-detail-tags">
              <span class="case-detail-tag case-detail-tag--accent">Logistics</span>
              <span class="case-detail-tag">Gas · Electricity · Water</span>
              <span class="case-detail-tag">14 sites</span>
            </div>

            <h1 data-reveal data-delay="1" class="case-detail-hero__title">
              28% cost reduction<br />across 14 logistics sites<br />in four weeks.
            </h1>
            <p data-reveal data-delay="2" class="case-detail-hero__intro">
              A national distribution operator had not reviewed their utility contracts in six years. We found £45,000 in annual overspend and fixed it — before they had to sign anything.
            </p>
          </div>

          <aside data-reveal="right" class="case-detail-hero__key-number" aria-label="Key result">
            <div class="case-detail-hero__key-value">£45k</div>
            <div class="case-detail-hero__key-label">annual saving</div>
          </aside>
        </div>
      </div>

      <div class="case-detail-metrics">
        <div class="container case-detail-metrics__grid">
          {heroMetrics.map(({ value, label }) => (
            <div class="case-detail-metrics__item">
              <div class="case-detail-metrics__value">{value}</div>
              <div class="case-detail-metrics__label">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="case-detail-section case-detail-section--white">
      <div class="container case-overview">
        <article class="case-overview__narrative">
          <p data-reveal class="eyebrow">The Situation</p>
          <h2 data-reveal data-delay="1" class="case-detail-heading">
            Six years. Fourteen sites. Zero contract reviews.
          </h2>

          <div data-reveal data-delay="2" class="case-detail-prose">
            <p>National Distribution Group is a mid-sized UK logistics operator with warehousing and distribution sites across the Midlands and South East. When they came to us in early 2025, their utility setup was, by their own description, "a mess we've been meaning to sort out for years."</p>
            <p>They had 14 sites. Each on a separate gas and electricity contract with different suppliers, different renewal dates, and different pricing structures. Three of the contracts had already silently rolled onto out-of-contract rates when their fixed terms expired. Nobody had noticed.</p>
            <p>Their finance team was spending around two days a month reconciling utility invoices. One site had been on a deemed rate for eight months following a lease renewal — a rate typically 40–60% above what a properly negotiated commercial contract would cost.</p>
            <p>They had also taken on a water contract for a new site that had never been benchmarked against the market. It was simply accepted from the previous tenant.</p>
          </div>
        </article>

        <aside data-reveal="right" class="case-sidebar">
          <section class="case-sidebar__card">
            <h3 class="case-sidebar__title">Client profile</h3>
            <dl class="case-profile">
              {clientProfile.map(({ label, value }) => (
                <div class="case-profile__row">
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))}
            </dl>
          </section>

          <section class="case-sidebar__card case-sidebar__card--dark">
            <h3 class="case-sidebar__title case-sidebar__title--light">Timeline</h3>
            <div class="case-timeline">
              {timeline.map(({ step, time }) => (
                <div class="case-timeline__row">
                  <span>{step}</span>
                  <strong>{time}</strong>
                </div>
              ))}
            </div>
          </section>

          <section class="case-sidebar__cta">
            <p class="case-sidebar__cta-title">Want to see what we'd find for you?</p>
            <p class="case-sidebar__cta-copy">Free audit. Response within 24 hours.</p>
            <a href="/contact" class="button button--primary">Get a free audit</a>
          </section>
        </aside>
      </div>
    </section>

    <section class="case-detail-section case-detail-section--soft case-challenge">
      <div class="case-detail-texture"></div>
      <div class="container">
        <div class="case-detail-section__header">
          <p data-reveal class="eyebrow">The Challenge</p>
          <h2 data-reveal data-delay="1" class="case-detail-heading">
            Three separate problems. All costing money simultaneously.
          </h2>
        </div>

        <div class="case-challenge__grid">
          {challenges.map(({ number, title, body, cost, costLabel, image }, i) => (
            <article data-reveal data-delay={String(i + 1)} class="case-challenge-card card-lift">
              <div class="case-challenge-card__media">
                <OptimizedImage src={image} alt={title} class="case-challenge-card__image" />
                <div class="case-challenge-card__overlay"></div>
                <div class="case-challenge-card__meta">
                  <span class="case-challenge-card__number">{number}</span>
                  <span class="case-challenge-card__cost">
                    <strong>{cost}</strong>
                    <span>{costLabel}</span>
                  </span>
                </div>
              </div>
              <div class="case-challenge-card__body">
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="case-detail-section case-detail-section--white">
      <div class="container case-approach">
        <figure data-reveal class="case-approach__media">
          <OptimizedImage
            src={warehouseDeskOperations}
            alt="Operations team reviewing contracts"
            class="case-approach__image"
            loading="lazy"
          />
          <div class="case-approach__overlay"></div>
          <figcaption class="case-approach__quote">
            <p>"We gave them one call and a copy of our last bill. Five days later we had a full breakdown of what we were overpaying and exactly what they could do about it."</p>
            <span>Operations Director, National Distribution Group</span>
          </figcaption>
        </figure>

        <article>
          <p data-reveal class="eyebrow">Our Approach</p>
          <h2 data-reveal data-delay="1" class="case-detail-heading">
            Audit first.<br />Negotiate second.<br />Admin handled.
          </h2>

          <div class="case-approach__steps">
            {approach.map(({ number, title, body }, i) => (
              <article data-reveal data-delay={String((i % 2) + 1)} class="case-approach-step">
                <span class="case-approach-step__number">{number}</span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                </div>
              </article>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="case-detail-section case-results">
      <div class="case-results__glow case-results__glow--top"></div>
      <div class="case-results__glow case-results__glow--bottom"></div>
      <div class="case-detail-texture case-detail-texture--light"></div>

      <div class="container">
        <div class="case-detail-section__header">
          <p data-reveal class="eyebrow eyebrow--muted">The Results</p>
          <h2 data-reveal data-delay="1" class="case-detail-heading case-detail-heading--light">
            £45,000 saved in year one.<br />Ongoing from there.
          </h2>
        </div>

        <div class="case-results__grid">
          {resultStats.map(({ value, label, sub }) => (
            <article data-reveal class="case-result-card">
              <div class="case-result-card__value">{value}</div>
              <h3>{label}</h3>
              <p>{sub}</p>
            </article>
          ))}
        </div>

        <div data-reveal class="case-results-table" role="table" aria-label="Savings breakdown">
          <div class="case-results-table__row case-results-table__row--head" role="row">
            <div role="columnheader">Utility</div>
            <div role="columnheader">Previous annual cost</div>
            <div role="columnheader">New annual cost</div>
            <div role="columnheader">Saving</div>
          </div>
          {resultRows.map(({ utility, previous, next, saving, percent }) => (
            <div class="case-results-table__row" role="row">
              <div role="cell">{utility}</div>
              <div role="cell">{previous}</div>
              <div role="cell">{next}</div>
              <div role="cell"><strong>{saving}</strong> <span>({percent})</span></div>
            </div>
          ))}
          <div class="case-results-table__row case-results-table__row--total" role="row">
            <div role="cell">Total</div>
            <div role="cell">£216,000</div>
            <div role="cell">£167,000</div>
            <div role="cell"><strong>£45,000+</strong> <span>(28%)</span></div>
          </div>
        </div>

        <div class="case-outcomes">
          {outcomes.map(({ title, body }, i) => (
            <article data-reveal data-delay={String(i + 1)} class="case-outcome-card">
              <span class="case-outcome-card__icon">
                <svg class="icon icon--medium" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="case-detail-section case-detail-section--white case-testimonial">
      <div class="container case-testimonial__inner">
        <div data-reveal class="case-testimonial__mark" aria-hidden="true">"</div>
        <blockquote data-reveal data-delay="1" class="case-testimonial__quote">
          We'd been meaning to look at this for two years. Every time it came up, something more urgent got in the way. Utility 1 sorted the whole thing in a month and saved us considerably more than we expected. The process required almost nothing from us. Honestly wish we'd done it sooner.
        </blockquote>

        <div data-reveal data-delay="2" class="case-testimonial__author">
          <span class="case-testimonial__avatar">SC</span>
          <span>
            <strong>Sarah Chen</strong>
            <span>Operations Director · National Distribution Group</span>
          </span>
          <span class="case-testimonial__divider"></span>
          <span class="case-testimonial__rating">
            <span aria-label="5 out of 5 stars">★★★★★</span>
            <small>5/5 rating</small>
          </span>
        </div>
      </div>
    </section>

    <section class="case-detail-section case-detail-section--soft case-more">
      <div class="container">
        <div class="section-header">
          <div>
            <p data-reveal class="eyebrow">More Case Studies</p>
            <h2 data-reveal data-delay="1" class="case-more__heading">More results. Different sectors.</h2>
          </div>
          <a data-reveal="right" href="/case-studies" class="button button--dark">View all case studies</a>
        </div>

        <div class="case-more__grid">
          {moreCases.map(({ image, sector, metric, title, savings, href }, i) => (
            <a data-reveal data-delay={String(i + 1)} href={href} class="case-more-card card-lift">
              <OptimizedImage src={image} alt={title} class="case-more-card__image" />
              <div class="case-more-card__overlay"></div>
              <div class="case-more-card__tags">
                <span>{sector}</span>
                <span>{metric}</span>
              </div>
              <div class="case-more-card__body">
                <h3>{title}</h3>
                <div class="case-more-card__footer">
                  <div>
                    <span>Annual saving</span>
                    <strong>{savings}</strong>
                  </div>
                  <span class="case-more-card__arrow"><svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="case-detail-section case-detail-section--white case-final-cta">
      <div class="container case-final-cta__inner">
        <p data-reveal class="eyebrow case-final-cta__eyebrow">Start Your Audit</p>
        <h2 data-reveal data-delay="1" class="case-detail-heading">
          Find out what you're overpaying.
        </h2>
        <p data-reveal data-delay="2" class="section-copy">
          Send us your latest utility bill. We'll come back within 24 hours with a clear picture of your options — no obligation, no hard sell.
        </p>
        <div data-reveal data-delay="3" class="case-final-cta__actions">
          <a href="/contact" class="button button--primary button--hero">
            Get a free audit
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="tel:08001234567" class="button button--dark">0800 123 4567</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
