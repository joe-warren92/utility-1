---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Services from '../components/Services.astro';
import CaseStudies from '../components/CaseStudies.astro';
import PainPoints from '../components/PainPoints.astro';
import WhyUs from '../components/WhyUs.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import About from '../components/About.astro';
import Insights from '../components/Insights.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import { wasteCollectionTrucks } from '../assets/images';
---

<Layout
  title="Utility 1 — Cut Commercial Utility Costs by Up to 28%"
  description="Utility 1 audits, renegotiates and manages all your commercial utilities. Gas, electricity, water and waste — one partner, one invoice, real savings."
  preloadImage={wasteCollectionTrucks}
  preloadImageSizes="100vw"
>
  <Nav />
  <Hero />
  <SocialProof />
  <Services />
  <CaseStudies />
  <PainPoints />
  <WhyUs />
  <HowItWorks />
  <Testimonials />
  <About />
  <Insights />
  <FinalCta />
  <Footer />
</Layout>
