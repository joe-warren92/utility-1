---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const proofStats = [
  { value: '500+', label: 'active clients' },
  { value: '£8.2M+', label: 'client savings delivered' },
  { value: '24 hrs', label: 'typical first response' },
];

const reviewSteps = [
  {
    title: 'Send your current setup',
    copy: 'Tell us what you spend, how many sites you manage and which utilities you want reviewed.',
  },
  {
    title: 'We audit the detail',
    copy: 'Our team checks rates, contract dates, billing lines, supplier terms and renewal risk.',
  },
  {
    title: 'You get clear options',
    copy: 'We show where savings may be available, what needs fixing and what we recommend next.',
  },
];

const contactMethods = [
  {
    label: 'Call us',
    value: '0800 123 4567',
    copy: 'Mon-Fri, 8am-6pm',
    href: 'tel:08001234567',
    icon: 'phone',
  },
  {
    label: 'Email us',
    value: 'hello@utility1.co.uk',
    copy: 'Response within one business day',
    href: 'mailto:hello@utility1.co.uk',
    icon: 'mail',
  },
];

const services = ['Gas', 'Electricity', 'Water', 'Waste', 'Merchant services', 'Asset management'];

const serviceLinks = [
  { label: 'Commercial gas', href: '/services/gas', copy: 'Contract renewals, rates and supplier terms.' },
  { label: 'Commercial electricity', href: '/services/electric', copy: 'Metering, billing checks and usage visibility.' },
  { label: 'Business water', href: '/services/water', copy: 'Water rates, leaks, billing and site checks.' },
  { label: 'Waste management', href: '/services/waste', copy: 'Collections, recycling streams and contract reviews.' },
  { label: 'Merchant services', href: '/services/merchant-services', copy: 'Payment costs, fees and card processing reviews.' },
  { label: 'Asset management', href: '/services/asset-management', copy: 'Asset records, compliance and estate visibility.' },
];
---

<Layout
  title="Book a Free Utility Review | Utility 1"
  description="Book a free no-obligation utility review with Utility 1. Get clear savings opportunities across gas, electricity, water, waste, merchant services and asset management."
>
  <Nav />

  <main class="contact-page">
    <section class="contact-hero">
      <div class="contact-hero__glow contact-hero__glow--top"></div>
      <div class="contact-hero__glow contact-hero__glow--bottom"></div>
      <div class="contact-hero__texture"></div>

      <div class="container contact-hero__grid">
        <div class="contact-hero__copy">
          <nav data-reveal class="contact-page-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span>/</span>
            <span>Contact</span>
          </nav>

          <p data-reveal class="eyebrow eyebrow--muted">Free Utility Review</p>
          <h1 data-reveal data-delay="1" class="contact-hero__title">
            Find out what your business is overpaying.
          </h1>
          <p data-reveal data-delay="2" class="contact-hero__intro">
            Book a free, no-obligation review of your current utility setup. We check contracts, rates, renewal dates and billing issues, then come back with clear opportunities within one business day.
          </p>

          <div data-reveal data-delay="3" class="contact-hero__actions">
            <a href="#review-form" class="button button--primary button--hero">
              Book free review
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:08001234567" class="button button--ghost">Call 0800 123 4567</a>
          </div>

          <div data-reveal data-delay="4" class="contact-proof">
            {proofStats.map(({ value, label }) => (
              <div class="contact-proof__item">
                <strong>{value}</strong>
                <span>{label}</span>
              </div>
            ))}
          </div>
        </div>

        <aside data-reveal="right" class="contact-review-panel" aria-label="Book your free review">
          <div class="contact-review-panel__header">
            <span>Free review</span>
            <strong>No obligation</strong>
          </div>

          <div class="contact-review-panel__testimonial">
            <p>"Utility 1 sorted the whole thing in a month and saved us considerably more than we expected."</p>
            <span>Sarah Chen, Operations Director</span>
          </div>

          <!-- TODO: Connect this static form to an external form handler before launch. -->
          <form id="review-form" class="form contact-review-form" action="#" method="post" data-static-form>
            <h2>Book your free review</h2>
            <p>Send a few details and we will come back within one business day.</p>

            <div class="form__row">
              <div>
                <label class="form__label" for="contact-first-name">First name</label>
                <input id="contact-first-name" name="first-name" type="text" placeholder="James" class="form__control" autocomplete="given-name" />
              </div>
              <div>
                <label class="form__label" for="contact-last-name">Last name</label>
                <input id="contact-last-name" name="last-name" type="text" placeholder="Thompson" class="form__control" autocomplete="family-name" />
              </div>
            </div>

            <div>
              <label class="form__label" for="contact-email">Business email</label>
              <input id="contact-email" name="email" type="email" placeholder="james@company.co.uk" class="form__control" autocomplete="email" />
            </div>

            <div>
              <label class="form__label" for="contact-phone">Phone number</label>
              <input id="contact-phone" name="phone" type="tel" placeholder="0800 123 4567" class="form__control" autocomplete="tel" />
            </div>

            <div>
              <label class="form__label" for="contact-company">Company name</label>
              <input id="contact-company" name="company" type="text" placeholder="Acme Ltd" class="form__control" autocomplete="organization" />
            </div>

            <div class="form__row">
              <div>
                <label class="form__label" for="contact-sites">Number of sites</label>
                <select id="contact-sites" name="sites" class="form__control">
                  <option value="">Select</option>
                  <option>1 site</option>
                  <option>2-5 sites</option>
                  <option>6-15 sites</option>
                  <option>16+ sites</option>
                </select>
              </div>
              <div>
                <label class="form__label" for="contact-spend">Annual spend</label>
                <select id="contact-spend" name="annual-spend" class="form__control">
                  <option value="">Select</option>
                  <option>Under £50,000/year</option>
                  <option>£50k - £150k/year</option>
                  <option>£150k - £500k/year</option>
                  <option>£500k+/year</option>
                </select>
              </div>
            </div>

            <div>
              <fieldset class="contact-review-form__fieldset">
                <legend class="form__label">What should we review?</legend>
                <div class="contact-service-options">
                {services.map((service) => (
                  <label>
                    <input type="checkbox" name="services" value={service} />
                    <span>{service}</span>
                  </label>
                ))}
                </div>
              </fieldset>
            </div>

            <div>
              <label class="form__label" for="contact-message">Anything useful to know?</label>
              <textarea id="contact-message" name="message" class="form__control contact-review-form__textarea" placeholder="Current supplier, renewal date, recent issue or priority area"></textarea>
            </div>

            <button type="submit" class="button button--primary form__submit">
              Request free review
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
            <p class="form__hint">No spam. No hard sell. Your review stays free and obligation-free.</p>
          </form>
        </aside>
      </div>
    </section>

    <section class="contact-page-section contact-page-section--white">
      <div class="container contact-support-grid">
        <div>
          <p data-reveal class="eyebrow">What Happens Next</p>
          <h2 data-reveal data-delay="1" class="contact-section-heading">A simple review process with clear next steps.</h2>
        </div>

        <div class="contact-steps">
          {reviewSteps.map(({ title, copy }, i) => (
            <article data-reveal data-delay={String(i + 1)} class="contact-step-card">
              <span>{String(i + 1).padStart(2, '0')}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="contact-page-section contact-page-section--soft">
      <div class="container contact-service-links">
        <div>
          <p data-reveal class="eyebrow">Review By Service</p>
          <h2 data-reveal data-delay="1" class="contact-section-heading">Start with the area that matters most.</h2>
          <p data-reveal data-delay="2" class="contact-section-copy">
            If you already know where the pressure is, these pages explain how we review each cost area before you book a free review.
          </p>
        </div>

        <nav class="contact-service-links__grid" aria-label="Utility review service pages">
          {serviceLinks.map(({ label, href, copy }, i) => (
            <a data-reveal data-delay={String(i + 1)} href={href} class="contact-service-link">
              <strong>{label}</strong>
              <span>{copy}</span>
            </a>
          ))}
        </nav>
      </div>
    </section>

    <section class="contact-page-section contact-page-section--white">
      <div class="container contact-info-grid">
        <div>
          <p data-reveal class="eyebrow">Contact Details</p>
          <h2 data-reveal data-delay="1" class="contact-section-heading">Prefer to speak first?</h2>
          <p data-reveal data-delay="2" class="contact-section-copy">
            Use whichever route is easiest. If you already have a bill or contract document, email it over and we can usually start the review straight away.
          </p>
        </div>

        <address class="contact-methods">
          {contactMethods.map(({ label, value, copy, href, icon }, i) => (
            <a data-reveal data-delay={String(i + 1)} href={href} class="contact-method-card">
              <span class="contact-method-card__icon">
                <svg class="icon icon--medium" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  {icon === 'phone' ? (
                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  ) : (
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  )}
                </svg>
              </span>
              <span class="contact-method-card__label">{label}</span>
              <strong>{value}</strong>
              <span class="contact-method-card__copy">{copy}</span>
            </a>
          ))}
        </address>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
