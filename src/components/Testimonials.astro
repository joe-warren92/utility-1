---
const testimonials = [
  {
    initials: 'SC',
    quote: "We'd been on the same gas contract for four years without realising it had rolled onto out-of-contract rates. Utility 1 spotted it in the first audit, renegotiated the whole thing, and we saved £28,000 in year one. Wish we'd called them sooner, honestly.",
    name: 'Sarah Chen',
    role: 'Operations Director · National Distribution Group',
    stat: '£28k year one',
  },
  {
    initials: 'MF',
    quote: "Our finance team was spending a full day every month just reconciling utility invoices across 15 sites. Utility 1 got everything into one invoice. We haven't had a billing dispute since. The saving was £32k but the time saving was probably worth as much again.",
    name: 'Michael Foster',
    role: 'Finance Manager · Sterling Facilities Ltd',
    stat: '15 sites, £32k',
  },
];
---

<section class="section testimonials">
  <div class="testimonials__glow testimonials__glow--top"></div>
  <div class="testimonials__glow testimonials__glow--bottom"></div>
  <div class="container">
    <div class="testimonials__header">
      <p data-reveal class="eyebrow eyebrow--muted">Client Feedback</p>
      <h2 data-reveal data-delay="1" class="section-heading section-heading--light">
        What they actually said.
      </h2>
    </div>

    <div class="testimonials__grid">
      {testimonials.map(({ initials, quote, name, role, stat }, i) => (
        <figure data-reveal data-delay={String(i + 1)} class="testimonial-card">
          <div class="testimonial-card__mark" aria-hidden="true">"</div>
          <div class="testimonial-card__stars" aria-hidden="true">
            {Array(5).fill(null).map(() => (
              <svg class="icon icon--small" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <blockquote class="testimonial-card__quote">"{quote}"</blockquote>
          <figcaption class="testimonial-card__author">
            <span class="testimonial-card__avatar">{initials}</span>
            <span>
              <span class="testimonial-card__name">{name}</span>
              <span class="testimonial-card__role">{role}</span>
            </span>
            <span class="testimonial-card__stat">{stat}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
