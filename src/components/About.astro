---
import OptimizedImage from './OptimizedImage.astro';
import { siteEnergyAudit } from '../assets/images';

const beliefs = [
  {
    wont: "We won't recommend a supplier we earn more commission from over a better deal for you.",
    will: "Every recommendation is the lowest cost option that meets your requirements — full stop.",
  },
  {
    wont: "We won't put you through a call centre when something goes wrong.",
    will: "You get a named account manager's direct number. Same person, every time.",
  },
  {
    wont: "We won't hide our commission in the contract small print.",
    will: "We're a regulated broker. Our fee structure is disclosed upfront before you sign anything.",
  },
];
---

<section id="about" class="section about">
  <div class="about__glow about__glow--top"></div>
  <div class="about__glow about__glow--bottom"></div>

  <div class="container">
    <div class="about__story">
      <div>
        <p data-reveal class="eyebrow">Who We Are</p>
        <h2 data-reveal data-delay="1" class="section-heading about__heading">
          Built by people who spent<br />14 years on the other side.
        </h2>

        <div data-reveal data-delay="2" class="section-copy about__copy">
          <p>
            Utility 1 was started in 2012 by James Hartley, after 14 years trading energy for two of the UK's largest suppliers. He knew exactly how commercial pricing worked — and exactly how much margin was being built in on the assumption that most businesses wouldn't look hard at their bills.
          </p>
          <p>
            The pitch to his first client was simple: send me your last utility bill and I'll show you what you're paying versus what you should be. If I find nothing, I charge you nothing. That's still how it works today.
          </p>
          <p>
            We're 14 people. We're not a national broker with 200 consultants and a call centre — and that's deliberate. Every client has a named account manager, we know your sites, and we pick up the phone when something goes wrong. That model doesn't scale to thousands of clients, but it means the clients we do have tend to stay for a long time.
          </p>
        </div>

        <div data-reveal data-delay="3" class="about-stats">
          {[
            { v: '2012', l: 'Year founded' },
            { v: '14', l: 'People on the team' },
            { v: '6.2 yrs', l: 'Avg. client tenure' },
          ].map(({ v, l }) => (
            <div class="about-stat">
              <div class="about-stat__value">{v}</div>
              <div class="about-stat__label">{l}</div>
            </div>
          ))}
        </div>
      </div>

      <div data-reveal="right" class="about__photo-wrap">
        <div class="media-card">
          <OptimizedImage src={siteEnergyAudit} alt="The Utility 1 team at work" class="media-card__image" sizes="(min-width: 980px) 45vw, 100vw" />
          <div class="media-card__overlay"></div>
          <div class="about__quote">
            <p>"Most clients have been with us longer than they were with their previous accountant. That's the standard we hold ourselves to."</p>
            <div class="about__quote-author">
              <span class="about__avatar">JH</span>
              <span>James Hartley · Founder</span>
            </div>
          </div>
        </div>
        <div class="about__badge">
          <div>FCA<br />Regulated</div>
          <span>since 2013</span>
        </div>
      </div>
    </div>

    <div class="about__beliefs">
      <div class="about__beliefs-glow"></div>
      <div class="about__beliefs-inner">
        <div class="about__beliefs-header">
          <p data-reveal class="eyebrow eyebrow--muted">Straight talk</p>
          <h3 data-reveal data-delay="1" class="about__beliefs-title">Things we won't do.</h3>
          <p data-reveal data-delay="2" class="about__beliefs-copy">Baked into how we operate. Not a marketing claim.</p>
        </div>

        <div class="about__belief-list">
          {beliefs.map(({ wont, will }, i) => (
            <article data-reveal data-delay={String(i + 1)} class="about__belief-row">
              <div class="about__belief-item about__belief-item--negative">
                <span class="about__belief-icon"><svg class="icon icon--medium" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 18L18 6M6 6l12 12"/></svg></span>
                <p>{wont}</p>
              </div>
              <div class="about__belief-item">
                <span class="about__belief-icon"><svg class="icon icon--medium" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span>
                <p>{will}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
