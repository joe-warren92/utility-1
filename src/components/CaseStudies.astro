---
import OptimizedImage from './OptimizedImage.astro';
import { distributionCentreExterior, recyclingMaterials, siteEnergyAudit } from '../assets/images';

const cases = [
  {
    image: distributionCentreExterior,
    sector: 'Logistics',
    metric: '28% cost reduction',
    title: 'Reducing operational costs by 28% for a national distribution centre',
    body: 'A 14-site logistics operator had not reviewed their utility contracts in six years. We renegotiated everything across gas, electricity and water in under four weeks.',
    savings: '£45,000',
    detail: 'annual saving',
    href: '/case-studies/national-distribution-centre',
  },
  {
    image: siteEnergyAudit,
    sector: 'Facilities Management',
    metric: '15 sites consolidated',
    title: 'Streamlining utility management for a multi-site operator',
    body: 'From 15 separate contracts to one consolidated account. One invoice. One point of contact.',
    savings: '£32,000',
    detail: 'annual saving',
    href: '/case-studies/sterling-facilities',
  },
  {
    image: recyclingMaterials,
    sector: 'Manufacturing',
    metric: '35% waste reduction',
    title: 'Cutting waste management costs for an industrial manufacturer',
    body: 'A full waste audit identified significant overspend and carrier duplication. Results delivered in eight weeks.',
    savings: '£18,500',
    detail: 'annual saving',
    href: '/case-studies/industrial-manufacturer',
  },
];
---

<section id="case-studies" class="section section--large section--dark case-studies">
  <div class="container">
    <div class="section-header">
      <div>
        <p data-reveal class="eyebrow eyebrow--muted">Case Studies</p>
        <h2 data-reveal data-delay="1" class="section-heading section-heading--light">
          Proven results.<br />Real numbers.
        </h2>
      </div>
      <div data-reveal="right" class="section-header__aside">
        <p class="section-copy section-copy--light">Every case study is a real client outcome, independently verifiable and free from inflated claims.</p>
        <a href="/case-studies" class="button button--primary">View all case studies</a>
      </div>
    </div>

    <div class="case-studies__grid">
      {cases.slice(0, 1).map((item) => (
        <a data-reveal href={item.href} class="case-card case-card--featured card-lift">
          <OptimizedImage src={item.image} alt={item.title} class="case-card__image" />
          <div class="case-card__overlay"></div>
          <div class="case-card__tags">
            <span class="case-card__tag">{item.sector}</span>
            <span class="case-card__tag case-card__tag--accent">{item.metric}</span>
          </div>
          <div class="case-card__content">
            <h3 class="case-card__title">{item.title}</h3>
            <p class="case-card__body">{item.body}</p>
            <div class="case-card__footer">
              <div>
                <div class="case-card__detail">{item.detail}</div>
                <div class="case-card__saving">{item.savings}</div>
              </div>
              <span class="case-card__arrow"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
          </div>
        </a>
      ))}

      <div class="case-studies__stack">
        {cases.slice(1).map((item, i) => (
          <a data-reveal data-delay={String(i + 2)} href={item.href} class="case-card card-lift">
            <OptimizedImage src={item.image} alt={item.title} class="case-card__image" />
            <div class="case-card__overlay"></div>
            <div class="case-card__tags">
              <span class="case-card__tag">{item.sector}</span>
              <span class="case-card__tag case-card__tag--accent">{item.metric}</span>
            </div>
            <div class="case-card__content">
              <h3 class="case-card__title">{item.title}</h3>
              <div class="case-card__footer">
                <div>
                  <div class="case-card__detail">{item.detail}</div>
                  <div class="case-card__saving">{item.savings}</div>
                </div>
                <span class="case-card__arrow"><svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div data-reveal="fade" class="case-studies__trust">
      <div class="case-studies__stats">
        {[
          { n: '£8.2M+', l: 'total client savings' },
          { n: '500+', l: 'businesses served' },
          { n: '12+', l: 'sectors covered' },
        ].map(({ n, l }) => (
          <div>
            <div class="case-studies__stat-value">{n}</div>
            <div class="case-studies__stat-label">{l}</div>
          </div>
        ))}
      </div>
      <p class="case-studies__note">All figures are independently verified client outcomes.</p>
    </div>
  </div>
</section>
