---
const articles = [
  {
    category: 'Energy Management',
    categoryColor: '#1e40af',
    categoryBg: '#eff6ff',
    title: '5 Ways to Reduce Your Commercial Energy Costs This Quarter',
    excerpt: 'Practical strategies finance and operations teams can implement immediately — no contract changes required.',
    date: 'March 15, 2026',
    read: '5 min',
  },
  {
    category: 'Industry Insights',
    categoryColor: '#6b21a8',
    categoryBg: '#faf5ff',
    title: 'Understanding Your Business Utility Contract: A Plain English Guide',
    excerpt: 'We break down the key clauses, hidden costs, and renewal traps buried in the average commercial utility contract.',
    date: 'March 10, 2026',
    read: '8 min',
  },
  {
    category: 'Sustainability',
    categoryColor: '#14532d',
    categoryBg: '#f0fdf4',
    title: 'How Smart Waste Management Can Improve Your Bottom Line',
    excerpt: 'Beyond compliance: how forward-thinking businesses are turning waste reduction into a measurable financial gain.',
    date: 'March 5, 2026',
    read: '6 min',
  },
];
---

<section class="py-32 bg-brand-off-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.025]" style="background-image: radial-gradient(circle at 1px 1px, #0f1923 1px, transparent 0); background-size: 32px 32px; pointer-events: none;"></div>

  <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-16">
      <div>
        <p data-reveal class="eyebrow">Insights &amp; Updates</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-[clamp(2.4rem,4.5vw,4rem)] text-brand-navy tracking-[-0.035em] leading-[1.02]">
          Latest from<br />our team
        </h2>
      </div>
      <div data-reveal="right">
        <p class="text-brand-gray text-[14.5px] leading-relaxed max-w-[340px] mb-5">
          Expert insight, industry news, and practical advice for commercial utility buyers.
        </p>
        <a href="#insights" class="inline-flex items-center gap-2 text-brand-navy text-[13.5px] font-semibold hover:text-brand-teal transition-colors tracking-[-0.01em]">
          View all articles →
        </a>
      </div>
    </div>

    <!-- Articles -->
    <div class="grid md:grid-cols-3 gap-6">
      {articles.map(({ category, categoryColor, categoryBg, title, excerpt, date, read }, i) => (
        <article
          data-reveal
          data-delay={String(i + 1)}
          class="card-lift group bg-white rounded-2xl overflow-hidden border border-black/6 cursor-pointer"
        >
          <!-- Top color bar -->
          <div class="h-1 bg-brand-teal/20 group-hover:bg-brand-teal transition-colors duration-400"></div>

          <div class="p-8">
            <span
              class="inline-block px-3 py-1 rounded-full text-[11px] font-semibold mb-5"
              style={`color: ${categoryColor}; background: ${categoryBg};`}
            >
              {category}
            </span>

            <h3 class="font-heading font-bold text-[1.05rem] text-brand-navy leading-snug tracking-[-0.02em] mb-3 group-hover:text-brand-teal transition-colors duration-200">{title}</h3>

            <p class="text-brand-gray text-[13.5px] leading-relaxed mb-6">{excerpt}</p>

            <div class="flex items-center justify-between pt-5 border-t border-black/6">
              <div class="flex items-center gap-2 text-brand-gray-light text-[12px]">
                <span>{date}</span>
                <span class="w-1 h-1 rounded-full bg-current"></span>
                <span>{read} read</span>
              </div>
              <div class="w-7 h-7 rounded-full bg-brand-ghost flex items-center justify-center group-hover:bg-brand-teal/10 transition-colors duration-200">
                <svg class="w-3.5 h-3.5 text-brand-navy group-hover:text-brand-teal transition-colors duration-200 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
