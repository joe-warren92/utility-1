---
const articles = [
  {
    category: 'Energy Management',
    title: '5 Ways to Reduce Your Commercial Energy Costs This Quarter',
    excerpt: 'Practical strategies finance and operations teams can implement immediately, no contract changes required.',
    date: 'March 15, 2026',
    read: '5 min',
    href: '/blog/reduce-commercial-energy-costs',
  },
  {
    category: 'Industry Insights',
    title: 'Understanding Your Business Utility Contract: A Plain English Guide',
    excerpt: 'We break down the key clauses, hidden costs, and renewal traps buried in the average commercial utility contract.',
    date: 'March 10, 2026',
    read: '8 min',
    href: '/blog/business-utility-contract-guide',
  },
  {
    category: 'Sustainability',
    title: 'How Smart Waste Management Can Improve Your Bottom Line',
    excerpt: 'Beyond compliance: how forward-thinking businesses are turning waste reduction into a measurable financial gain.',
    date: 'March 5, 2026',
    read: '6 min',
    href: '/blog/smart-waste-management-bottom-line',
  },
];
---

<section id="insights" class="section section--large insights">
  <div class="insights__texture"></div>
  <div class="container">
    <div class="section-header">
      <div>
        <p data-reveal class="eyebrow">Insights &amp; Updates</p>
        <h2 data-reveal data-delay="1" class="section-heading">
          Latest from<br />our team
        </h2>
      </div>
      <div data-reveal="right" class="section-header__aside">
        <p class="section-copy">Expert insight, industry news, and practical advice for commercial utility buyers.</p>
        <a href="/blog" class="text-link">View all articles -></a>
      </div>
    </div>

    <div class="insight-grid">
      {articles.map(({ category, title, excerpt, date, read, href }, i) => (
        <a data-reveal data-delay={String(i + 1)} href={href} class="insight-card card-lift">
          <div class="insight-card__bar"></div>
          <div class="insight-card__body">
            <span class="insight-card__category">{category}</span>
            <h3 class="insight-card__title">{title}</h3>
            <p class="insight-card__copy">{excerpt}</p>
            <div class="insight-card__footer">
              <span>{date}</span>
              <span class="insight-card__dot"></span>
              <span>{read} read</span>
              <span class="insight-card__arrow"><svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
