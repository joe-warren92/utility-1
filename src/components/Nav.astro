---
import Logo from './Logo.astro';

const services = [
  { label: 'Commercial Gas', href: '/services/gas' },
  { label: 'Commercial Electricity', href: '/services/electric' },
  { label: 'Water', href: '/services/water' },
  { label: 'Waste', href: '/services/waste' },
  { label: 'Merchant Services', href: '/services/merchant-services' },
  { label: 'Asset Management', href: '/services/asset-management' },
];

const links = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<header id="nav" class="site-header">
  <div id="nav-bg" class="site-header__backdrop"></div>

  <div class="container">
    <div class="site-header__inner">
      <a href="/" class="site-header__brand" aria-label="Utility 1 home">
        <span class="site-header__mark">
          <Logo class="site-header__logo" />
        </span>
        <span class="site-header__brand-text">
          <span class="site-header__brand-name">UTILITY</span>
          <span class="site-header__brand-suffix">1 LTD</span>
        </span>
      </a>

      <nav class="site-header__nav" aria-label="Primary navigation">
        <a href="/" class="site-header__link">Home</a>

        <div class="site-header__dropdown">
          <a href="/services" class="site-header__dropdown-trigger">
            Services
            <svg class="site-header__dropdown-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </a>
          <div class="site-header__dropdown-panel">
            <div class="site-header__dropdown-menu">
              {services.map(({ label, href }) => (
                <a href={href} class="site-header__dropdown-item">
                  {label}
                </a>
              ))}
              <div class="site-header__dropdown-footer">
                <a href="/services" class="site-header__dropdown-item">View all services -></a>
              </div>
            </div>
          </div>
        </div>

        <a href="/case-studies" class="site-header__link">Case Studies</a>
        <a href="/blog" class="site-header__link">Blog</a>
        <a href="/contact" class="site-header__link">Contact</a>
      </nav>

      <a href="/contact" class="site-header__cta">Get Free Review</a>

      <button id="mobile-menu-toggle" class="site-header__menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="site-header__mobile-menu" hidden>
    <div class="container">
      <nav class="site-header__mobile-panel" aria-label="Mobile navigation">
        <div class="site-header__mobile-section">
          {links.map(({ label, href }) => (
            <a href={href} class="site-header__mobile-link">{label}</a>
          ))}
        </div>

        <div class="site-header__mobile-section">
          <span class="site-header__mobile-heading">Services</span>
          {services.map(({ label, href }) => (
            <a href={href} class="site-header__mobile-service">
              <span>{label}</span>
            </a>
          ))}
        </div>

        <a href="/contact" class="button button--primary site-header__mobile-cta">Get Free Review</a>
      </nav>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const menu = document.getElementById('mobile-menu');
  const toggle = document.getElementById('mobile-menu-toggle');
  let scrolled = false;

  const closeMenu = () => {
    if (!menu || !toggle || !nav) return;
    menu.hidden = true;
    nav.classList.remove('site-header--open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
  };

  window.addEventListener('scroll', () => {
    const nextScrolled = window.scrollY > 60;
    if (nextScrolled !== scrolled && nav) {
      scrolled = nextScrolled;
      nav.classList.toggle('site-header--scrolled', scrolled);
    }
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    if (!menu || !nav) return;
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    menu.hidden = isOpen;
    nav.classList.toggle('site-header--open', !isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 980) closeMenu();
  });
</script>
