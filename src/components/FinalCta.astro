---
---

<section id="contact" class="relative py-36 overflow-hidden bg-white">
  <!-- Offset background -->
  <div class="absolute inset-y-0 right-0 w-[45%] bg-brand-ghost pointer-events-none hidden lg:block"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[400px] bg-brand-teal/4 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative max-w-[1360px] mx-auto px-8 xl:px-12">
    <div class="grid lg:grid-cols-2 gap-20 items-start">

      <!-- Left: Form -->
      <div>
        <p data-reveal class="eyebrow">Get Started</p>
        <h2 data-reveal data-delay="1" class="font-heading font-bold text-[clamp(2.4rem,4.5vw,4rem)] text-brand-navy tracking-[-0.035em] leading-[1.02] mb-4">
          Ready to simplify<br /><span class="text-brand-teal">your utilities?</span>
        </h2>
        <p data-reveal data-delay="2" class="text-brand-gray text-[15px] leading-relaxed mb-12 max-w-[420px]">
          Get a free, no-obligation review of your current setup. We will show you exactly where you could save — with no jargon, and no hard sell.
        </p>

        <!-- TODO: Connect this static form to an external form handler before launch. -->
        <form data-reveal data-delay="3" class="space-y-4 max-w-[480px]" onsubmit="return false;">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[12.5px] font-semibold text-brand-navy tracking-[-0.01em] mb-2">First name</label>
              <input type="text" placeholder="James" class="w-full px-4 py-3.5 rounded-[8px] border border-black/12 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-3 focus:ring-brand-teal/10 transition-all duration-200" />
            </div>
            <div>
              <label class="block text-[12.5px] font-semibold text-brand-navy tracking-[-0.01em] mb-2">Last name</label>
              <input type="text" placeholder="Thompson" class="w-full px-4 py-3.5 rounded-[8px] border border-black/12 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-3 focus:ring-brand-teal/10 transition-all duration-200" />
            </div>
          </div>
          <div>
            <label class="block text-[12.5px] font-semibold text-brand-navy tracking-[-0.01em] mb-2">Business email</label>
            <input type="email" placeholder="james@company.co.uk" class="w-full px-4 py-3.5 rounded-[8px] border border-black/12 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-3 focus:ring-brand-teal/10 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-[12.5px] font-semibold text-brand-navy tracking-[-0.01em] mb-2">Company name</label>
            <input type="text" placeholder="Acme Ltd" class="w-full px-4 py-3.5 rounded-[8px] border border-black/12 bg-white text-brand-navy text-[14px] placeholder:text-brand-gray-light/60 focus:outline-none focus:border-brand-teal focus:ring-3 focus:ring-brand-teal/10 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-[12.5px] font-semibold text-brand-navy tracking-[-0.01em] mb-2">Annual utility spend (approx.)</label>
            <select class="w-full px-4 py-3.5 rounded-[8px] border border-black/12 bg-white text-brand-navy text-[14px] focus:outline-none focus:border-brand-teal focus:ring-3 focus:ring-brand-teal/10 transition-all duration-200 appearance-none cursor-pointer">
              <option value="">Select a range</option>
              <option>Under £50,000/year</option>
              <option>£50k – £150k/year</option>
              <option>£150k – £500k/year</option>
              <option>£500k+/year</option>
            </select>
          </div>
          <button type="submit" class="btn-primary w-full justify-center py-4 text-[14.5px]">
            Get your free review
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          <p class="text-center text-brand-gray-light text-[12px]">No obligation. No spam. Responses within one business day.</p>
        </form>
      </div>

      <!-- Right: Contact + proof -->
      <div class="pt-0 lg:pt-20">

        <!-- Download card -->
        <div data-reveal="right" class="p-8 rounded-2xl bg-brand-navy mb-5">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-brand-teal/15 border border-brand-teal/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-heading font-bold text-white text-[1.05rem] mb-1 tracking-[-0.02em]">Free Utilities Guide</h3>
              <p class="text-white/45 text-[13px] mb-5 leading-relaxed">The plain-English guide to commercial utility management. 24 pages of actionable insight.</p>
              <button class="btn-ghost text-[13px] py-2.5">Download guide</button>
            </div>
          </div>
        </div>

        <!-- Contact tiles -->
        <div data-reveal="right" data-delay="2" class="grid grid-cols-2 gap-4 mb-5">
          <a href="tel:08001234567" class="group p-5 bg-white rounded-xl border border-black/8 hover:border-brand-teal/30 hover:shadow-lg hover:shadow-brand-teal/5 transition-all duration-300">
            <div class="w-8 h-8 bg-brand-teal/10 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-4 h-4 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-gray-light mb-0.5">Call us</div>
            <div class="font-heading font-bold text-brand-navy text-[15px] tracking-[-0.02em]">0800 123 4567</div>
            <div class="text-brand-gray-light text-[12px] mt-0.5">Mon–Fri, 8am–6pm</div>
          </a>
          <a href="mailto:hello@utility1.co.uk" class="group p-5 bg-white rounded-xl border border-black/8 hover:border-brand-teal/30 hover:shadow-lg hover:shadow-brand-teal/5 transition-all duration-300">
            <div class="w-8 h-8 bg-brand-teal/10 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-4 h-4 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-gray-light mb-0.5">Email us</div>
            <div class="font-heading font-bold text-brand-navy text-[14.5px] tracking-[-0.02em] break-all">hello@utility1.co.uk</div>
            <div class="text-brand-gray-light text-[12px] mt-0.5">Response within 24hrs</div>
          </a>
        </div>

        <!-- Trust strip -->
        <div data-reveal="right" data-delay="3" class="p-5 rounded-xl border border-black/6 bg-brand-ghost">
          <div class="flex flex-wrap gap-5">
            {[
              { n: '500+', l: 'Active clients' },
              { n: '12+', l: 'Years experience' },
              { n: '£8.2M', l: 'Savings delivered' },
            ].map(({ n, l }) => (
              <div>
                <div class="font-heading font-bold text-brand-navy text-[1.2rem] tracking-[-0.03em] leading-none">{n}</div>
                <div class="text-brand-gray-light text-[11.5px] mt-0.5">{l}</div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
