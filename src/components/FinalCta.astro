---
---

<section id="contact" class="section section--large contact">
  <div class="contact__offset"></div>
  <div class="contact__glow"></div>

  <div class="container contact__grid">
    <div>
      <p data-reveal class="eyebrow">Get Started</p>
      <h2 data-reveal data-delay="1" class="section-heading">
        Ready to simplify<br /><span class="section-heading__accent">your utilities?</span>
      </h2>
      <p data-reveal data-delay="2" class="section-copy contact__intro">
        Get a free, no-obligation review of your current setup. We will show you exactly where you could save — with no jargon, and no hard sell.
      </p>

      <!-- TODO: Connect this static form to an external form handler before launch. -->
      <form data-reveal data-delay="3" class="form" action="#" method="post" data-static-form>
        <div class="form__row">
          <div>
            <label class="form__label" for="final-first-name">First name</label>
            <input id="final-first-name" name="first-name" type="text" placeholder="James" class="form__control" autocomplete="given-name" />
          </div>
          <div>
            <label class="form__label" for="final-last-name">Last name</label>
            <input id="final-last-name" name="last-name" type="text" placeholder="Thompson" class="form__control" autocomplete="family-name" />
          </div>
        </div>
        <div>
          <label class="form__label" for="final-email">Business email</label>
          <input id="final-email" name="email" type="email" placeholder="james@company.co.uk" class="form__control" autocomplete="email" />
        </div>
        <div>
          <label class="form__label" for="final-company">Company name</label>
          <input id="final-company" name="company" type="text" placeholder="Acme Ltd" class="form__control" autocomplete="organization" />
        </div>
        <div>
          <label class="form__label" for="final-spend">Annual utility spend (approx.)</label>
          <select id="final-spend" name="annual-spend" class="form__control">
            <option value="">Select a range</option>
            <option>Under £50,000/year</option>
            <option>£50k – £150k/year</option>
            <option>£150k – £500k/year</option>
            <option>£500k+/year</option>
          </select>
        </div>
        <button type="submit" class="button button--primary form__submit">
          Get your free review
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
        <p class="form__hint">No obligation. No spam. Responses within one business day.</p>
      </form>
    </div>

    <div class="contact__aside">
      <div data-reveal="right" class="contact-card">
        <div class="contact-card__icon">
          <svg class="icon icon--medium" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        </div>
        <div>
          <h3 class="contact-card__title">Free Utilities Guide</h3>
          <p class="contact-card__copy">The plain-English guide to commercial utility management. 24 pages of actionable insight.</p>
          <button class="button button--ghost">Download guide</button>
        </div>
      </div>

      <div data-reveal="right" data-delay="2" class="contact-tiles">
        <a href="tel:08001234567" class="contact-tile">
          <span class="contact-tile__icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></span>
          <span class="contact-tile__label">Call us</span>
          <span class="contact-tile__value">0800 123 4567</span>
          <span class="contact-tile__copy">Mon–Fri, 8am–6pm</span>
        </a>
        <a href="mailto:hello@utility1.co.uk" class="contact-tile">
          <span class="contact-tile__icon"><svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></span>
          <span class="contact-tile__label">Email us</span>
          <span class="contact-tile__value">hello@utility1.co.uk</span>
          <span class="contact-tile__copy">Response within 24hrs</span>
        </a>
      </div>

      <div data-reveal="right" data-delay="3" class="contact__trust">
        {[
          { n: '500+', l: 'Active clients' },
          { n: '12+', l: 'Years experience' },
          { n: '£8.2M', l: 'Savings delivered' },
        ].map(({ n, l }) => (
          <div>
            <div class="contact__trust-value">{n}</div>
            <div class="contact__trust-label">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
