---
import OptimizedImage from './OptimizedImage.astro';
import { operationsReview } from '../assets/images';

const values = [
  'No hidden fees',
  'No lock-in contracts',
  'Dedicated account manager',
];

const cards = [
  {
    title: 'Transparency',
    body: 'Every cost breakdown is explained in plain English. Nothing buried, nothing hidden.',
    stat: '100% cost visibility',
  },
  {
    title: 'Flexibility',
    body: 'No lock-ins. No surprise escalations. Contracts structured around your operational needs.',
    stat: 'Zero hidden clauses',
  },
  {
    title: 'Support',
    body: 'Real people. Real responses. A named account manager who actually knows your business.',
    stat: 'Named account manager',
  },
];
---

<section class="section section--large cta-banner">
  <div class="cta-banner__media">
    <OptimizedImage src={operationsReview} alt="" class="cta-banner__image" />
    <div class="cta-banner__overlay cta-banner__overlay--side"></div>
    <div class="cta-banner__overlay cta-banner__overlay--bottom"></div>
    <div class="cta-banner__glow"></div>
  </div>

  <div class="container cta-banner__grid">
    <div>
      <p data-reveal class="eyebrow eyebrow--muted">Built for Businesses</p>
      <h2 data-reveal data-delay="1" class="cta-banner__title">
        Clarity over<br /><span class="accent">complexity.</span><br />Always.
      </h2>
      <p data-reveal data-delay="2" class="section-copy section-copy--light cta-banner__copy">
        We do not believe in contracts you cannot understand, or fees you cannot justify. Every pound saved is visible. Every decision is yours.
      </p>
      <div data-reveal data-delay="3" class="hero__actions">
        <a href="/contact" class="button button--primary">Get your free review</a>
        <a href="tel:08001234567" class="button button--ghost">0800 123 4567</a>
      </div>

      <div data-reveal data-delay="4" class="cta-banner__checks">
        {values.map((item) => (
          <div class="cta-banner__check">
            <svg class="icon icon--small accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
            {item}
          </div>
        ))}
      </div>
    </div>

    <div class="cta-banner__cards">
      {cards.map(({ title, body, stat }, i) => (
        <article data-reveal data-delay={String(i + 1)} class="cta-banner__card">
          <div class="cta-banner__icon">
            <svg class="icon icon--medium" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <div class="cta-banner__card-header">
              <h3 class="cta-banner__card-title">{title}</h3>
              <span class="cta-banner__stat">{stat}</span>
            </div>
            <p class="cta-banner__card-copy">{body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
