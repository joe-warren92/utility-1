---
import Logo from './Logo.astro';

const company = [
  { label: 'About Us', href: '/#about' },
  { label: 'Services', href: '/services' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const services = [
  { label: 'All Services', href: '/services' },
  { label: 'Gas', href: '/services/gas' },
  { label: 'Electricity', href: '/services/electric' },
  { label: 'Water', href: '/services/water' },
  { label: 'Waste', href: '/services/waste' },
  { label: 'Merchant Services', href: '/services/merchant-services' },
  { label: 'Asset Management', href: '/services/asset-management' },
];

const legal = [
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
  { label: 'Cookies', href: '/cookies' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__brand-column">
        <div class="site-footer__brand-lockup">
          <span class="site-footer__mark">
            <Logo class="site-footer__logo" />
          </span>
          <span>
            <span class="site-footer__brand">UTILITY</span>
            <span class="site-footer__suffix">1 LTD</span>
          </span>
        </div>
        <p class="site-footer__copy">
          Auditing, renegotiating and managing commercial utilities across the UK since 2012.
        </p>
        <div class="site-footer__badges">
          {['ISO 9001', 'FCA Reg.', 'Trustpilot'].map((badge) => <span class="site-footer__badge">{badge}</span>)}
        </div>
        <div class="site-footer__socials">
          <a href="https://www.linkedin.com/" aria-label="LinkedIn" class="site-footer__social">LI</a>
          <a href="https://x.com/" aria-label="X" class="site-footer__social">X</a>
        </div>
      </div>

      <div>
        <h2 class="site-footer__heading">Company</h2>
        <ul class="site-footer__list">
          {company.map(({ label, href }) => <li><a href={href} class="site-footer__link">{label}</a></li>)}
        </ul>
      </div>

      <div>
        <h2 class="site-footer__heading">Services</h2>
        <ul class="site-footer__list">
          {services.map(({ label, href }) => <li><a href={href} class="site-footer__link">{label}</a></li>)}
        </ul>
      </div>

      <div class="site-footer__cta">
        <h2 class="site-footer__heading">Get started</h2>
        <div class="site-footer__cta-card">
          <p class="site-footer__cta-copy">Ready to see where you could save? Get your free review today.</p>
          <a href="/contact" class="button button--primary">
            Get free review
            <svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <div class="site-footer__phone">0800 123 4567 | Mon-Fri, 8am-6pm</div>
        </div>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>&copy; 2026 Utility 1 Ltd. Registered in England &amp; Wales. Company No. 07843291.</p>
      <div class="site-footer__legal">
        {legal.map(({ label, href }) => <a href={href} class="site-footer__link">{label}</a>)}
      </div>
    </div>
  </div>
</footer>
