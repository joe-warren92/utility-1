---
const steps = [
  {
    n: '01',
    title: 'Free Review',
    body: 'We analyse your current contracts, spending, and consumption across every utility. No obligation. Just clarity.',
    time: '24–48 hours',
  },
  {
    n: '02',
    title: 'Tailored Proposal',
    body: 'A clear, jargon-free breakdown of exactly how we reduce your costs and simplify your operations.',
    time: '2–3 days',
  },
  {
    n: '03',
    title: 'We Handle the Switch',
    body: 'We handle every detail — paperwork, provider coordination, setup. You carry on running your business.',
    time: '2–4 weeks',
  },
  {
    n: '04',
    title: 'Ongoing Support',
    body: 'Continuous monitoring, proactive renewal management, and expert advice. We never disappear after contract sign.',
    time: 'Always on',
  },
];
---

<section id="how-it-works" class="section section--large how-it-works">
  <div class="how-it-works__glow"></div>
  <div class="container">
    <div class="how-it-works__header">
      <p data-reveal class="eyebrow">How It Works</p>
      <h2 data-reveal data-delay="1" class="section-heading">
        Four steps.<br />Most clients save within 30 days.
      </h2>
      <p data-reveal data-delay="2" class="section-copy">
        Designed to be painless. Most clients are fully onboarded with costs already reduced within four weeks.
      </p>
    </div>

    <div class="process-list process-list--editorial">
      {steps.map(({ n, title, body, time }, i) => (
        <article data-reveal="fade" data-delay={String((i % 2) + 1)} class="process-step process-step--large">
          <div class="process-step__number">{n}</div>
          <div>
            <h3 class="process-step__title">{title}</h3>
            <p class="process-step__copy">{body}</p>
          </div>
          <div class="process-step__timeline">
            <div class="process-step__timeline-label">Timeline</div>
            <div class="process-step__timeline-value">{time}</div>
            <div class="process-step__rule"></div>
          </div>
        </article>
      ))}
    </div>

    <div data-reveal class="how-it-works__cta">
      <a href="/contact" class="button button--primary">
        Start your free review
        <svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <span class="how-it-works__note">No commitment required</span>
    </div>
  </div>
</section>
