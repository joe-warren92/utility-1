---
import OptimizedImage from './OptimizedImage.astro';
import {
  distributionCentreExterior,
  siteEnergyAudit,
  stockroomInventory,
  warehouseDeskOperations,
  warehouseOperator,
  wasteCollectionTrucks,
} from '../assets/images';

const services = [
  {
    name: 'Gas',
    href: '/services/gas',
    description: 'Flexible contracts engineered around your operational profile. We benchmark the market quarterly to ensure you are always on a competitive rate.',
    tag: 'Core Service',
    saving: '£4,200',
    savingLabel: 'avg. saving',
    reduction: '18% avg. reduction',
    image: siteEnergyAudit,
  },
  {
    name: 'Electricity',
    href: '/services/electric',
    description: 'Competitive rates, transparent billing, and smart half-hourly data analysis for commercial electricity. No surprises.',
    tag: 'Core Service',
    saving: '£5,800',
    savingLabel: 'avg. saving',
    reduction: '22% avg. reduction',
    image: warehouseDeskOperations,
  },
  {
    name: 'Water',
    href: '/services/water',
    description: 'Smart consumption management to lower spend and reduce waste at source. We audit, benchmark, and negotiate on your behalf.',
    saving: '£1,600',
    savingLabel: 'avg. saving',
    reduction: '15% avg. reduction',
    image: distributionCentreExterior,
  },
  {
    name: 'Waste',
    href: '/services/waste',
    description: 'Comprehensive disposal solutions that cut costs and shrink your environmental footprint. Includes carrier compliance and waste auditing.',
    saving: '£2,100',
    savingLabel: 'avg. saving',
    reduction: '35% avg. reduction',
    image: wasteCollectionTrucks,
  },
  {
    name: 'Merchant Services',
    href: '/services/merchant-services',
    description: 'Competitive transaction rates with full PCI compliance support. Integrated terminal solutions for single and multi-site operations.',
    saving: '0.4%',
    savingLabel: 'lower transaction rate',
    reduction: 'Save on every transaction',
    image: warehouseOperator,
  },
  {
    name: 'Asset Management',
    href: '/services/asset-management',
    description: 'Expert maintenance, lifecycle planning, and optimisation for all utility infrastructure. Prevent costly failures before they happen.',
    saving: '18%',
    savingLabel: 'efficiency gain',
    reduction: 'Reduce downtime & costs',
    image: stockroomInventory,
  },
];
---

<section id="services" class="section section--large services">
  <div class="container">
    <div class="section-header">
      <div>
        <p data-reveal class="eyebrow">Our Services</p>
        <h2 data-reveal data-delay="1" class="section-heading">
          Every utility.<br />One trusted partner.
        </h2>
      </div>
      <div data-reveal="right" class="section-header__aside">
        <div class="services__client-row">
          <div class="services__avatars" aria-hidden="true">
            {['S','M','J','L'].map(l => <div class="services__avatar">{l}</div>)}
          </div>
          <span class="services__client-count">500+ active clients</span>
        </div>
        <p class="services__client-copy">
          Average combined saving of <strong>£12,400/year</strong> per client.
        </p>
      </div>
    </div>

    <div class="card-grid">
      {services.map(({ name, href, description, tag, saving, savingLabel, reduction, image }, i) => (
        <div data-reveal data-delay={String((i % 3) + 1)} class="services__card card-lift">
          <div class="services__image-wrap">
            <OptimizedImage src={image} alt={name} class="services__image" />
            <div class="services__saving">
              <div>
                <div class="services__saving-value">{saving}</div>
                <div class="services__saving-label">{savingLabel}</div>
              </div>
              {tag && <span class="services__tag">{tag}</span>}
            </div>
          </div>

          <div class="services__body">
            <div class="services__card-header">
              <h3 class="services__card-title">{name}</h3>
              <span class="services__reduction">{reduction}</span>
            </div>
            <p class="services__description">{description}</p>
            <div class="services__learn-more">
              Learn more
              <svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <a class="services__overlay-link" href={href} aria-label={`Learn more about ${name}`}></a>
          </div>
        </div>
      ))}
    </div>

    <div data-reveal class="services__cta">
      <div>
        <p class="services__cta-title">Ready to find out how much you could save?</p>
        <p class="services__cta-copy">Free review. No obligation. Most clients see results within 30 days.</p>
      </div>
      <a href="/contact" class="button button--primary">
        Get free savings review
        <svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
