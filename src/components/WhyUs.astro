---
import OptimizedImage from './OptimizedImage.astro';
import { warehouseDeskOperations } from '../assets/images';

const points = [
  { t: 'We find the overcharges first', d: 'The first audit is free. We benchmark your current spend against the market and show you exactly what you\'re overpaying — before we ask you to sign anything.' },
  { t: 'No auto-renewing into bad rates', d: 'We track every contract end date across your portfolio and act before the deadline. You will never roll onto an out-of-contract rate again.' },
  { t: 'One invoice. Every utility.', d: 'Gas, electricity, water and waste — consolidated into a single monthly statement you can actually read. No more chasing four different suppliers.' },
  { t: 'A named person, not a call centre', d: 'You get a dedicated account manager who knows your sites, your usage patterns, and your renewal schedule. Same person every time.' },
];
---

<section class="section why-us">
  <div class="why-us__offset"></div>
  <div class="container split-grid why-us__grid">
    <div class="why-us__content">
      <p data-reveal class="eyebrow">Why Clients Stay</p>
      <h2 data-reveal data-delay="1" class="section-heading">
        Most clients find<br />£8,000–£45,000 in the<br />first audit alone.
      </h2>
      <p data-reveal data-delay="2" class="section-copy">
        We have been doing this since 2012. We know where commercial utility costs go wrong, and we have the supplier relationships to fix them quickly.
      </p>

      <div class="feature-list why-us__list">
        {points.map(({ t, d }, i) => (
          <div data-reveal data-delay={String(i + 1)} class="feature-list__item">
            <span class="feature-list__icon"><svg class="icon icon--small" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20,6 9,17 4,12"/></svg></span>
            <div>
              <p class="feature-list__title">{t}</p>
              <p class="feature-list__copy">{d}</p>
            </div>
          </div>
        ))}
      </div>

      <div data-reveal class="hero__actions">
        <a href="/contact" class="button button--dark">Get a free audit</a>
        <a href="/case-studies" class="text-link">See real results -></a>
      </div>
    </div>

    <div data-reveal="right" class="why-us__media">
      <div class="media-card">
        <OptimizedImage src={warehouseDeskOperations} alt="Commercial warehouse operations" class="media-card__image" sizes="(min-width: 980px) 45vw, 100vw" />
        <div class="media-card__overlay media-card__overlay--subtle"></div>
      </div>
      <div class="floating-stat">
        <div class="floating-stat__label">First audit result</div>
        <div class="floating-stat__value">£28,400</div>
        <div class="floating-stat__copy">recovered for a logistics client</div>
      </div>
      <div class="floating-badge">
        <div class="floating-badge__label">Typical timeline</div>
        <div class="floating-badge__value">4 weeks</div>
        <div class="floating-badge__copy">from audit to saving</div>
      </div>
    </div>
  </div>
</section>
