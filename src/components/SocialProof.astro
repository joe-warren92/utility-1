---
import { Image } from 'astro:assets';
import { logoipsum211 } from '../assets/images';

const placeholders = Array.from({ length: 8 });
---

<section class="social-proof" aria-label="Trusted by UK businesses">
  <div class="social-proof__track" aria-hidden="true">
    {[...placeholders, ...placeholders].map(() => (
      <span class="social-proof__logo">
        <Image
          src={logoipsum211}
          alt=""
          width={180}
          height={56}
          loading="lazy"
          decoding="async"
        />
      </span>
    ))}
  </div>
</section>
