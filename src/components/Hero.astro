---
import OptimizedImage from './OptimizedImage.astro';
import { wasteCollectionTrucks } from '../assets/images';
---

<section class="hero">
  <div class="hero__media">
    <OptimizedImage
      src={wasteCollectionTrucks}
      alt=""
      class="hero__image"
      loading="eager"
      fetchpriority="high"
      sizes="100vw"
      widths={[640, 960, 1280, 1440, 1600]}
    />
    <div class="hero__overlay hero__overlay--primary"></div>
    <div class="hero__overlay hero__overlay--bottom"></div>
    <div class="hero__glow"></div>
  </div>

  <div class="hero__content">
    <div class="container">
      <div data-reveal class="hero__trust-row">
        <div class="hero__badge">
          <div class="hero__stars" aria-hidden="true">
            {Array(5).fill(null).map(() => (
              <svg class="icon icon--small" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <span>4.9/5 | 500+ UK businesses</span>
        </div>
        <div class="hero__badge hero__badge--accent">
          <span class="hero__status-dot"></span>
          <span>Trusted commercial partner since 2012</span>
        </div>
      </div>

      <div data-reveal data-delay="1">
        <h1 class="hero__title">
          <span class="hero__title-line">Cut utility costs</span>
          <span class="hero__title-line accent">by up to 28%.</span>
        </h1>
      </div>

      <p data-reveal data-delay="2" class="hero__copy">
        We audit your current contracts, find the overcharges, renegotiate on your behalf, and manage everything going forward. Gas, electricity, water and waste handled.
      </p>

      <div data-reveal data-delay="3" class="hero__stats">
        {[
          { v: 'Up to 28%', l: 'cost reduction' },
          { v: 'GBP 12,400', l: 'avg. annual saving' },
          { v: '12+', l: 'years experience' },
        ].map(({ v, l }) => (
          <div class="hero__stat">
            <div class="hero__stat-value">{v}</div>
            <div class="hero__stat-label">{l}</div>
          </div>
        ))}
      </div>

      <div data-reveal data-delay="4" class="hero__actions">
        <a href="/contact" class="button button--primary button--hero">
          Get my free review
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/services" class="button button--ghost">Explore services</a>
        <a href="tel:08001234567" class="hero__phone">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0800 123 4567
        </a>
      </div>
    </div>
  </div>

  <div class="hero__stats-bar">
    <div class="container">
      <div class="hero__bar-grid">
        {[
          { v: 'GBP 12,400', l: 'avg. annual saving' },
          { v: '28%', l: 'cost reduction' },
          { v: '4.9/5', l: 'client rating' },
          { v: '500+', l: 'active clients' },
          { v: '12+', l: 'years experience' },
          { v: 'GBP 8.2M', l: 'savings delivered' },
        ].map(({ v, l }, i) => (
          <div data-reveal="fade" data-delay={String((i % 6) + 1)} class="hero__bar-item">
            <div class="hero__bar-value">{v}</div>
            <div class="hero__bar-label">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
